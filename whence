def _prior_tag(body: str) -> dict:
    # Greedy to the line's closing ` -->` so the nested "prov" object is captured
    # whole; the tag lives on one line, so `.` (no DOTALL) can't overrun it.
    m = re.search(r"<!-- whence (\{.*\}) -->", body or "")
    if m:
        try: return json.loads(m.group(1))
        except Exception: pass
    return {}


def prior_labels(body: str) -> list:
    return _prior_tag(body).get("labels", [])


def prior_prov(body: str) -> dict:
    return _prior_tag(body).get("prov", {})


def _now_epoch() -> int:
    return int(datetime.datetime.now(datetime.timezone.utc).timestamp())


def _throttled(name: str, secs: int) -> bool:
    """True at most once per `secs`, recording the tick — so the maintenance the
    hook does (sweep, self-update) doesn't run on every single tool call."""
    st = CFG_DIR / f".last-{name}"
    try: last = int(st.read_text().strip())
    except Exception: last = 0
    if _now_epoch() - last < secs:
        return False
    st.parent.mkdir(parents=True, exist_ok=True)
    st.write_text(str(_now_epoch()))
    return True


def is_stamped(body: str) -> bool:
    return bool(MARK_RE.search(body or ""))


AUDIT_LOG = CFG_DIR / "audit.jsonl"


def _audit(cfg: dict, record: dict) -> None:
    """Append one line to the audit log if `audit_log` is on. Off by default; the
    flag lives in the synced config, so flipping it on/off reaches the whole fleet.
    Records who/what/when + before -> after so a wrong label is traceable to the
    exact write that made it. Never raises — observability must not break a stamp."""
    if not cfg.get("audit_log"):
        return
    try:
        AUDIT_LOG.parent.mkdir(parents=True, exist_ok=True)
        with AUDIT_LOG.open("a") as fh:
            fh.write(json.dumps(record, ensure_ascii=False) + "\n")
    except Exception:
        pass


def apply_stamp(pr: str, p: dict, cfg: dict, post_labels: bool, post_footer: bool,
                repo: str = "", source: str = "manual") -> list:
    """Write the labels + footer for provenance `p` onto PR #pr. Idempotent:
    replaces whence's own prior labels/footer, never stacks. Shared by the live
    hook path and the ledger sweep so both stamp identically.

    `repo` ("owner/name") is REQUIRED for correctness whenever the caller knows
    it: without it every `gh` call resolves the PR number against the cwd's repo,
    so a sweep running from an unrelated checkout would stamp a same-numbered PR
    in the WRONG repository."""
    R = ["--repo", repo] if repo else []
    labels = labels_for(p, cfg) if post_labels else []
    names = [n for n, _ in labels]
    ft = footer(p, cfg, names) if post_footer else ""
    body = sh(GH, "pr", "view", pr, *R, "--json", "body", "-q", ".body").stdout
    before = {"labels": prior_labels(body), "prov": prior_prov(body)}
    keep = set(names)
    existing = sh(GH, "pr", "view", pr, *R, "--json", "labels", "-q", ".labels[].name").stdout.split("\n")
    stale = (set(prior_labels(body)) | {l for l in existing if l and l.startswith(OLD_PREFIXES)}) - keep
    for s in sorted(x for x in stale if x):
        sh(GH, "pr", "edit", pr, *R, "--remove-label", s)
    for n, c in labels:
        sh(GH, "label", "create", n, *R, "--color", c, "--force")
    if names:
        sh(GH, "pr", "edit", pr, *R, *sum([["--add-label", n] for n in names], []))
    stripped = MARK_RE.sub("", body).rstrip()
    newbody = (stripped + "\n\n" + ft) if post_footer else (stripped + "\n")
    if newbody != body:
        fd, tmpname = tempfile.mkstemp(prefix="whence-body-", suffix=".md")
        try:
            os.write(fd, newbody.encode()); os.close(fd)
            sh(GH, "pr", "edit", pr, *R, "--body-file", tmpname)
        finally:
            try: os.unlink(tmpname)
            except OSError: pass
    after = {"labels": names, "prov": {"agent": p.get("agent", ""), "tab": p.get("tab", "")}}
    if before != after:                       # only log a real change, not a no-op re-stamp
        _audit(cfg, {"ts": datetime.datetime.now(datetime.timezone.utc)
                            .strftime("%Y-%m-%d %H:%M:%S UTC"),
                     "pr": pr, "repo": repo, "source": source,
                     "by": f"{p.get('agent','?')}@{p.get('host','?')}",
                     "before": before, "after": after})
    return names


# ── Branch→provenance ledger + sweep ────────────────────────────────────────
# Reliable coverage without an orchestrator hook. The live in-shell stamp only
# sees a PR it can resolve at push time from the agent's cwd — it MISSES a PR
# opened inside a git worktree (the hook runs from the home cwd, wrong branch),
# one opened later by a detached daemon (e.g. shipyard-local), one opened
# elsewhere while this shell only pushed, and one whose create command was
# killed before the hook ran. So split the work: CAPTURE the branch's provenance
# when the push/PR command fires (env is live then), and SWEEP later — stamp
# whatever PR turns up for that branch, using the captured provenance. Keyed on
# the git branch, which every path shares, so it needs no Shipyard dependency.
LEDGER = CFG_DIR / "branch-ledger.json"
DEFAULT_BRANCHES = {"main", "master", "trunk", "develop"}


def _git(cwd, *a):
    return sh("git", "-C", cwd, *a) if cwd else sh("git", *a)


_ASSIGN_TOKEN_RE = re.compile(r"^([A-Za-z_]\w*)=(.*)$", re.S)


def _without_heredoc_bodies(cmd: str) -> str:
    """Remove heredoc data, where action-looking text is never shell syntax."""
    pending: list[tuple[str, bool]] = []
    out = []
    for line in cmd.splitlines(keepends=True):
        if pending:
            delimiter, strip_tabs = pending[0]
            value = line.rstrip("\r\n")
            if strip_tabs:
                value = value.lstrip("\t")
            if value == delimiter:
                pending.pop(0)
            out.append("\n" if line.endswith(("\n", "\r")) else "")
            continue
        out.append(line)
        quote, escaped, i = "", False, 0
        while i < len(line):
            ch = line[i]
            if escaped:
                escaped = False
                i += 1
                continue
            if ch == "\\" and quote != "'":
                escaped = True
                i += 1
                continue
            if quote:
                if ch == quote:
                    quote = ""
                i += 1
                continue
            if ch in ("'", '"'):
                quote = ch
                i += 1
                continue
            if line.startswith("<<", i) and not line.startswith("<<<", i):
                j, strip_tabs = i + 2, False
                if j < len(line) and line[j] == "-":
                    strip_tabs, j = True, j + 1
                while j < len(line) and line[j] in " \t":
                    j += 1
                delim_quote = line[j] if j < len(line) and line[j] in ("'", '"') else ""
                if delim_quote:
                    j += 1
                start = j
                while j < len(line) and (line[j] != delim_quote if delim_quote
                                         else line[j] not in " \t\r\n;&|<>()"):
                    j += 1
                delimiter = line[start:j]
                if delimiter:
                    pending.append((delimiter, strip_tabs))
                i = j + (1 if delim_quote and j < len(line) else 0)
                continue
            i += 1
    return "".join(out)


def _simple_shell_commands(cmd: str) -> list[list[str]]:
    """Tokenize top-level shell commands without executing or expanding them.

    Splitting only on unquoted control operators keeps diagnostic literals such
    as ``rg "shipyard pr"`` inside the ``rg`` argv. This is intentionally a
    small shell recognizer, not an evaluator: malformed input yields whatever
    complete commands preceded it and never runs user text.
    """
    if not cmd:
        return []
    segments, buf, quote, escaped, comment = [], [], "", False, False

    def flush():
        text = "".join(buf).strip()
        buf.clear()
        if text:
            segments.append(text)

    for ch in _without_heredoc_bodies(cmd):
        if comment:
            if ch == "\n":
                comment = False
                flush()
            continue
        if escaped:
            buf.append(ch)
            escaped = False
            continue
        if ch == "\\" and quote != "'":
            buf.append(ch)
            escaped = True
            continue
        if quote:
            buf.append(ch)
            if ch == quote:
                quote = ""
            continue
        if ch in ("'", '"'):
            quote = ch
            buf.append(ch)
        elif ch == "#" and (not buf or buf[-1].isspace()):
            comment = True
        elif ch in ";\n&|()":
            flush()
        else:
            buf.append(ch)
    flush()
    out = []
    for segment in segments:
        try:
            tokens = shlex.split(segment, posix=True)
        except ValueError:
            continue
        if tokens:
            out.append(tokens)
    return out


def _resolve_cmd_path(raw: str, vars_: dict[str, str], cwd: str | None = None):
    value = raw.strip().strip("'\"")
    value = re.sub(r"\$\{?(\w+)\}?", lambda m: vars_.get(m.group(1), ""), value)
    value = os.path.expanduser(os.path.expandvars(value))
    if value and not os.path.isabs(value):
        value = os.path.join(cwd or os.getcwd(), value)
    value = os.path.abspath(value) if value else ""
    return value if value and os.path.isdir(value) else None


def _command_action(cmd: str) -> tuple[bool, bool, str | None]:
    """Return (creates_pr, pushes, cwd) for the first real action command.

    The executable position matters: words passed to ``rg``, ``echo``, ``git
    log -S``, or another diagnostic are data, not actions. The cwd is the shell's
    effective directory at the action itself, before any later diagnostic ``cd``.
    """
    vars_: dict[str, str] = {}
    cwd = None
    for tokens in _simple_shell_commands(cmd):
        i = 0
        while i < len(tokens):
            assignment = _ASSIGN_TOKEN_RE.match(tokens[i])
            if not assignment:
                break
            vars_[assignment.group(1)] = assignment.group(2).strip("'\"")
            i += 1
        if i >= len(tokens):
            continue
        argv = tokens[i:]
        if argv[0] == "cd" and len(argv) > 1:
            got = _resolve_cmd_path(argv[1], vars_, cwd)
            if got:
                cwd = got
            continue
        while argv and argv[0] in ("command", "builtin", "nohup"):
            argv = argv[1:]
        if argv and argv[0] == "env":
            argv = argv[1:]
            while argv and (_ASSIGN_TOKEN_RE.match(argv[0]) or argv[0].startswith("-")):
                argv = argv[1:]
        if not argv:
            continue
        exe = os.path.basename(argv[0])
        if any(arg in ("-h", "--help", "--version", "--dry-run") for arg in argv[1:]):
            continue
        if exe in ("shipyard", "pulp") and len(argv) > 1 and argv[1] == "pr":
            return True, True, cwd
        if exe in ("gh", "ghapp") and argv[1:3] == ["pr", "create"]:
            return True, False, cwd
        if exe == "git":
            git_cwd, j = cwd, 1
            while j < len(argv) and argv[j].startswith("-"):
                if argv[j] in ("-C", "-c", "--git-dir", "--work-tree") and j + 1 < len(argv):
                    if argv[j] == "-C":
                        git_cwd = _resolve_cmd_path(argv[j + 1], vars_, cwd)
                    j += 2
                else:
                    j += 1
            if j < len(argv) and argv[j] == "push":
                return False, True, git_cwd
    return False, False, None


def _cmd_cwd(cmd: str):
    """The directory the command actually ran in, read out of the command itself.

    This is what stands between a worktree PR and no label at all. A backgrounded
    `shipyard pr` returns no output for parse_outcome to read, and the hook's own
    cwd is the session root — so the `cd` in the command text is the ONLY thing
    left that names the worktree. It has to handle how the commands are really
    written, not just the tidy form:

        cd /wt && shipyard pr          cd on one line, command on the next
        WT=/wt                         a variable, expanded below
        cd "$WT"                       quoted, and referencing that variable
        git -C /wt push                no cd at all

    Associates the action with the cwd in force at that point. A later ``cd``
    used for diagnostics or cleanup cannot redirect the capture to another repo.
    Only real directories are accepted; an unresolved path means we learned
    nothing, not that the action ran there."""
    return _command_action(cmd)[2]


def _repo_branch(cwd):
    url = _git(cwd, "config", "--get", "remote.origin.url").stdout.strip()
    m = re.search(r"[:/]([^/]+/[^/]+?)(?:\.git)?$", url)
    slug = m.group(1) if m else ""
    br = _git(cwd, "rev-parse", "--abbrev-ref", "HEAD").stdout.strip()
    return slug, br


def _load_ledger() -> dict:
    try: return json.loads(LEDGER.read_text()) if LEDGER.exists() else {}
    except Exception: return {}


def _recent_prs(raw: str, rec: dict) -> list[dict]:
    """Return PRs created for this ledger capture, not older branch-name reuse.

    The captured HEAD is the identity boundary: branch names alone can collide
    with old PRs or forks. The creation time only bounds that exact commit to the
    current hook invocation, allowing five seconds of clock/order skew.
    """
    try:
        prs = json.loads(raw or "[]")
    except Exception:
        return []
    not_before = int(rec.get("ts", 0))
    captured_head = rec.get("head", "")
    if not captured_head:
        return []
    recent = []
    for pr in prs:
        value = pr.get("createdAt", "")
        try:
            created = int(datetime.datetime.fromisoformat(
                value.replace("Z", "+00:00")
            ).timestamp())
        except (TypeError, ValueError):
            continue
        if created >= not_before - 5 and pr.get("headRefOid") == captured_head:
            recent.append(pr)
    return recent


def ledger_record(cmd: str, p: dict, slug: str = "", br: str = "",
                  source_ref: str = "", hook_cwd: str = "") -> str:
    """Remember which tab/session/machine owns this branch, keyed owner/repo#branch.

    `slug`/`br` come from the command's own output when it named them — always
    correct. Only when it named neither do we fall back to reading git in the
    hook's cwd, which is right just when the command ran in the session's root
    checkout (and wrong, silently, for every worktree)."""
    cmd_cwd = _cmd_cwd(cmd) or (hook_cwd if os.path.isdir(hook_cwd) else None)
    if not slug or not br:
        c_slug, c_br = _repo_branch(cmd_cwd)
        slug, br = slug or c_slug, br or c_br
    if not slug or not br or br in ("HEAD", ""):
        return ""
    if br in DEFAULT_BRANCHES:
        # A push to main is not a PR branch. Recording it would leave the sweep
        # asking "any PR with head=main?" — and stamp whatever unrelated PR that
        # matched, with this session's provenance.
        return ""
    led = _load_ledger()
    key = f"{slug}#{br}"
    head = _git(cmd_cwd, "rev-parse", source_ref or br or "HEAD").stdout.strip()
    led[key] = {"p": {k: p.get(k, "") for k in FIELDS},
                "ts": _now_epoch(), "head": head}
    LEDGER.parent.mkdir(parents=True, exist_ok=True)
    LEDGER.write_text(json.dumps(led))
    return key


def _is_ref_tab(tab: str, cfg: dict) -> bool:
    """A name-free tab: the cmux ref (`surface:16`) or the redaction placeholder.
    These are placeholders the sweep should try to upgrade to the real name."""
    t = (tab or "").strip()
    return bool(re.fullmatch(r"surface:\d+", t)) or t == cfg.get("redact_placeholder", "(redacted)")


def _prov_good(prov: dict, cfg: dict) -> bool:
    """A stamp worth freezing: a real (named, non-placeholder) tab AND a known
    agent. Anything less is degraded and stays eligible for healing."""
    tab = (prov.get("tab") or "").strip()
    agent = (prov.get("agent") or "").strip()
    return bool(tab) and not _is_ref_tab(tab, cfg) and agent not in ("", "unknown")


def _prov_better(best: dict, cur: dict, cfg: dict) -> bool:
    """`best` is worth re-stamping over `cur` only when it supplies something cur
    lacks — a named tab where cur has none/a ref, or a known agent where cur has
    `unknown`. Never fires for a mere rename (named -> different name), so a good
    stamp is frozen, not chased."""
    def tab_real(pr): 
        t = (pr.get("tab") or "").strip()
        return bool(t) and not _is_ref_tab(t, cfg)
    def agent_real(pr): return (pr.get("agent") or "") not in ("", "unknown")
    return (tab_real(best) and not tab_real(cur)) or (agent_real(best) and not agent_real(cur))


_SURF_UUID = re.compile(r"[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12}")


def _best_provenance(rec: dict, cfg: dict, body: str = "") -> tuple[dict, str]:
    """The best provenance available NOW for a ledgered branch: the captured
    ledger fields, but with the tab re-read LIVE from cmux when the ledger's tab
    is missing or a bare ref (the title has usually settled to its real name by
    the time the timer runs). Prefers the ledger's captured name when it has one,
    so a later rename isn't chased. Returns (provenance, surface_id).

    The surface id is taken from the ledger, falling back to the PR's own footer
    (its jump line) — a PR first-stamped in a degraded context still carries the
    surface UUID there even when the ledger entry never got it."""
    p = {f: rec.get("p", {}).get(f, "") for f in FIELDS}
    p["_redacted"] = []
    m = (_SURF_UUID.search(p.get("jump", "") or p.get("relaunch", ""))
         or _SURF_UUID.search(body or ""))
    surf = m.group(0) if m else ""
    if surf and (not p.get("tab") or _is_ref_tab(p.get("tab", ""), cfg)):
        tab, ref = cmux_tab_title(surf)
        if tab:
            p["tab"] = f"{tab} ({ref})" if ref else tab
        elif not p.get("tab"):
            p["tab"] = _surface_ref(surf)
    redact(p, cfg, surf)
    return p, surf


def sweep(cfg: dict) -> int:
    """Stamp — and HEAL — every ledgered branch's PR. Prunes entries >14 days old.

    Two jobs in one pass:
    - unstamped PR  -> stamp it from the best provenance available now.
    - stamped-but-degraded PR (blank/ref tab, or `unknown` agent) -> re-stamp when
      the tab has since settled to a real name (re-read live) or the ledger holds
      better data. A GOOD stamp is frozen — a rename is never chased.

    `--state all` so a merged-on-green PR is covered, not just open ones. An entry
    is marked done once its PR is good (or unrecoverable — the tab's surface is
    gone), so a healed queue costs one `pr list` per branch and no re-stamps."""
    led = _load_ledger()
    if not led:
        return 0
    post_labels, post_footer = cfg["labels"], cfg["footer"]
    now, keep, n = _now_epoch(), {}, 0
    for key, rec in led.items():
        if now - rec.get("ts", 0) > 14 * 86400:
            continue
        keep[key] = rec
        slug, _, br = key.partition("#")
        if not slug or not br or rec.get("done"):
            continue
        res = sh(GH, "pr", "list", "--repo", slug, "--head", br,
                 "--state", "all", "--json", "number,body")
        try: prs = json.loads(res.stdout or "[]")
        except Exception: prs = []
        for pr in prs:
            num, body = str(pr["number"]), pr.get("body", "")
            best, surf = _best_provenance(rec, cfg, body)
            best_labels = [x for x, _ in labels_for(best, cfg)]
            if not is_stamped(body):
                apply_stamp(num, best, cfg, post_labels, post_footer, repo=slug, source="sweep:new")
                n += 1
                rec["done"] = _prov_good(best, cfg)
                continue
            if prior_labels(body) == best_labels:      # already matches best — nothing to gain
                rec["done"] = _prov_good(best, cfg) or not (surf and _surface_ref(surf))
                continue
            cur = prior_prov(body)
            if _prov_good(cur, cfg):                   # good stamp — freeze, don't chase renames
                rec["done"] = True
                continue
            if _prov_better(best, cur, cfg):           # degraded, and best is an upgrade — heal it
                apply_stamp(num, best, cfg, post_labels, post_footer, repo=slug, source="sweep:heal")
                n += 1
                rec["done"] = _prov_good(best, cfg)
            else:                                      # can't improve yet; retry only while the tab lives
                rec["done"] = not (surf and _surface_ref(surf))
    LEDGER.write_text(json.dumps(keep))
    return n


def retry_pending_pr(key: str, cfg: dict, attempts: int = 24, delay: float = 5.0,
                     max_wait: float = 120.0) -> int:
    """Promptly stamp one ledgered PR that an orchestrator creates asynchronously.

    A backgrounded ``shipyard pr`` can return a task handle before GitHub has a
    PR to name. The normal hook records the branch correctly, but its immediate
    sweep is then too early; without this targeted retry the PR waits for the
    10-minute global timer. Poll only the exact repo/branch, for at most two
    minutes, and leave ledger completion to the normal sweep so this worker never
    races a concurrent hook while rewriting the whole ledger.
    """
    rec = _load_ledger().get(key)
    slug, sep, br = key.partition("#")
    if not rec or not sep or not slug or not br:
        return 0
    deadline = time.monotonic() + max_wait
    for attempt in range(max(1, attempts)):
        remaining = deadline - time.monotonic()
        if remaining <= 0:
            break
        res = sh(GH, "pr", "list", "--repo", slug, "--head", br,
                 "--state", "all", "--json", "number,body,createdAt,headRefOid",
                 timeout=max(0.1, min(5.0, remaining)))
        prs = _recent_prs(res.stdout, rec)
        if prs:
            for pr in prs:
                body = pr.get("body", "")
                if is_stamped(body):
                    continue
                best, _surf = _best_provenance(rec, cfg, body)
                apply_stamp(str(pr["number"]), best, cfg, cfg["labels"], cfg["footer"],
                            repo=slug, source="retry")
            return 0
        remaining = deadline - time.monotonic()
        if attempt + 1 < max(1, attempts) and remaining > 0:
            time.sleep(min(delay, remaining))
    return 0


def _spawn_retry(key: str, cfg: dict, post_labels: bool, post_footer: bool) -> bool:
    """Start the targeted retry out of process so an agent hook never blocks."""
    argv = [sys.executable, os.path.realpath(sys.argv[0]), "--retry-key", key]
    hidden = sorted(cfg.get("hide", set()))
    if hidden:
        argv.extend(["--hide", ",".join(hidden)])
    if not post_labels:
        argv.append("--no-labels")
    if not post_footer:
        argv.append("--no-footer")
    try:
        subprocess.Popen(
            argv,
            stdin=subprocess.DEVNULL,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
            close_fds=True,
        )
        return True
    except OSError:
        return False


def maybe_retry_deferred_pr(hook_is_pr: bool, hook_pr: str, ledger_key: str,
                            cfg: dict, post_labels: bool, post_footer: bool) -> bool:
    """Schedule a retry only when a PR command returned before naming its PR."""
    if not hook_is_pr or hook_pr or not ledger_key:
        return False
    return _spawn_retry(ledger_key, cfg, post_labels, post_footer)


def preexec_capture(cwd: str, cfg: dict, post_labels: bool, post_footer: bool) -> str:
    """Capture a long-running orchestrator before it starts and retry in parallel.

    The shell wrapper calls this synchronously while its cwd and cmux/session
    environment are still exact. Only the tiny local ledger write is synchronous;
    GitHub polling happens in the existing detached, bounded retry worker while
    ``shipyard pr`` or ``pulp pr`` continues running.
    """
    if not cwd or not os.path.isdir(cwd):
        return ""
    slug, br = _repo_branch(cwd)
    top = _git(cwd, "rev-parse", "--show-toplevel").stdout.strip()
    if ((top and (pathlib.Path(top) / ".whence-off").exists())
            or not slug or not br or not repo_allowed(cfg, slug)):
        return ""
    p = collect(cfg)
    p["path"] = sanitize_path(cwd, cfg)
    key = ledger_record("", p, slug, br, "HEAD", cwd)
    if key:
        _spawn_retry(key, cfg, post_labels, post_footer)
    return key


def show_log(n: int) -> int:
    """Pretty-print the last n audit entries: when, which PR, what triggered it,
    who, and the label transition. Reads ~/.config/whence/audit.jsonl."""
    if not AUDIT_LOG.exists():
        print(f"whence: no audit log yet ({AUDIT_LOG}).\n"
              f"  turn it on with `whence --audit on` (syncs to the fleet), then wait for a stamp.")
        return 0
    lines = AUDIT_LOG.read_text().splitlines()[-n:]
    if not lines:
        print("whence: audit log is empty"); return 0
    for ln in lines:
        try: r = json.loads(ln)
        except Exception: continue
        b = ", ".join(r.get("before", {}).get("labels", [])) or "—"
        a = ", ".join(r.get("after", {}).get("labels", [])) or "—"
        print(f"  {r.get('ts','?')}  #{r.get('pr','?')} {r.get('repo','')}"
              f"  [{r.get('source','?')}]  {r.get('by','?')}")
        print(f"      [{b}]  ->  [{a}]")
    print(f"\n  ({len(lines)} shown · {AUDIT_LOG})")
    return 0


def set_audit(on: bool) -> int:
    """Flip the audit_log flag in config.json. Because config syncs via the private
    repo, this reaches every machine — turn it on to validate, off when done."""
    f = CFG_DIR / "config.json"
    try: d = json.loads(f.read_text()) if f.exists() else {}
    except Exception: d = {}
    d["audit_log"] = on
    f.parent.mkdir(parents=True, exist_ok=True)
    f.write_text(json.dumps(d, indent=2) + "\n")
    print(f"whence: audit_log {'ON' if on else 'OFF'} (config.json)"
          + ("  — the config watcher will sync it to the fleet" if _backup_ready() else ""))
    return 0


def reorder_labels(cfg: dict, repo: str) -> int:
    """Force the label chips on OPEN PRs into agent -> host -> workspace -> tab order.

    GitHub renders issue/PR labels in label-CREATION-id order, globally — there is
    no per-PR order control (proven: re-adding in a different order does nothing;
    delete+recreate moves a label to the end). So this deletes and recreates each
    whence label in role order, giving ascending ids, then re-applies them to the
    open PRs. Labels are classified by their whence COLOR, so it never touches
    unrelated repo labels (bug/enhancement/…). Deleting a label also strips it from
    CLOSED PRs — acceptable, since the chips there don't matter — the provenance
    footer is untouched either way. New tab labels created later get the newest ids
    and naturally sort last; re-run this only if a new agent/host/workspace appears."""
    color2role = {cfg["colors"].get(r, ""): r for r in LABEL_FIELDS}
    order = {r: i for i, r in enumerate(LABEL_FIELDS)}
    res = sh(GH, "pr", "list", "--repo", repo, "--state", "open", "--limit", "100",
             "--json", "number,labels")
    try: prs = json.loads(res.stdout or "[]")
    except Exception: prs = []
    buckets, per_pr = {}, {}                       # name -> (role, color) ; pr -> [names]
    for pr in prs:
        keep = []
        for l in pr.get("labels", []):
            role = color2role.get(l.get("color", ""))
            if role is None:
                continue                           # not whence-colored — leave it alone
            buckets[l["name"]] = (role, l["color"])
            keep.append(l["name"])
        if keep:
            per_pr[pr["number"]] = keep
    if not buckets:
        print(f"whence: no whence labels on open PRs in {repo} — nothing to reorder")
        return 0
    ordered = sorted(buckets.items(), key=lambda kv: (order[kv[1][0]], kv[0].lower()))
    print(f"whence: reordering {len(ordered)} label(s) across {len(per_pr)} open PR(s):")
    print("  " + "  ->  ".join(n for n, _ in ordered))
    for name, _ in ordered:
        sh(GH, "label", "delete", name, "--repo", repo, "--yes")
    for name, (_, color) in ordered:              # recreate in role order == chip order
        sh(GH, "label", "create", name, "--repo", repo, "--color", color, "--force")
    for num, labels in per_pr.items():
        sh(GH, "pr", "edit", str(num), "--repo", repo,
           *sum([["--add-label", l] for l in labels], []))
    print(f"whence: reapplied labels to {len(per_pr)} open PR(s)")
    return 0


def gc_labels(cfg: dict, repo: str) -> int:
    """Delete every repo-level label whose name trips the denylist.

    Redaction keeps whence from CREATING a denied label, but one can already exist
    — created before you added the term, or by another tool — and a repo label
    lives in the picker/autocomplete even after it's pulled off every PR. Deleting
    the label removes it from every PR at once. Scoped to one repo and explicit
    (never on a timer): deleting labels is destructive and cross-cutting."""
    if not cfg.get("denylist"):
        print("whence: denylist is empty — nothing to gc"); return 0
    res = sh(GH, "label", "list", "--repo", repo, "--limit", "500",
             "--json", "name", "-q", ".[].name")
    if res.returncode != 0:
        print(f"whence: could not list labels for {repo}: {res.stderr.strip()}",
              file=sys.stderr)
        return 1
    hits = [n for n in res.stdout.splitlines() if n.strip() and denied(n, cfg)]
    if not hits:
        print(f"whence: no denied labels in {repo}"); return 0
    for n in hits:
        r = sh(GH, "label", "delete", n, "--repo", repo, "--yes")
        print(f"  {'deleted' if r.returncode == 0 else 'FAILED '} {n!r}"
              + (f"  ({denied(n, cfg)})" if r.returncode == 0 else f"  {r.stderr.strip()}"))
    return 0


# ── Multi-machine sync: self-update (pull) + deploy (fan-out) ────────────────
# Any machine can be the one you edit whence on. Two mechanisms keep the rest
# current: self_update() converges each machine to origin/main automatically
# (throttled, from the hook — no cron, no push from the author); deploy() pushes
# your change and SSHes your personal host list to pull+reinstall instantly. The
# host list lives only in ~/.config/whence/hosts, never in the repo, because it's
# specific to your fleet — other whence users don't need it.
HOSTS = CFG_DIR / "hosts"
CONFIG_FILE = CFG_DIR / "config.json"
BACKUP_DIR = CFG_DIR / "config-repo"          # a clone of your private config repo
# `gh` (which GitHub CLI this box uses) is the one field allowed to differ per
# machine, so a pull never overwrites it. Identity lives in the separate host-label
# file, so the rest of config.json is fleet policy every machine should share.
CONFIG_LOCAL_KEYS = {"gh"}


def _read_json(path: pathlib.Path) -> dict:
    try: return json.loads(path.read_text()) if path.exists() else {}
    except Exception: return {}


def _shareable(cfg: dict) -> dict:
    return {k: v for k, v in cfg.items() if k not in CONFIG_LOCAL_KEYS}


def _backup_ready() -> bool:
    return (BACKUP_DIR / ".git").exists()


def pull_config() -> bool:
    """Inbound sync: fast-forward the config repo and merge fleet policy into this
    machine's config.json, preserving its machine-local keys. Writes ONLY if the
    result differs — so a no-op pull never churns the file (or trips the push
    watcher). This is the offline catch-up: it runs on the sweep timer, so a
    machine that was asleep when you edited converges on its next tick after waking.
    Returns True if the local config changed."""
    if not _backup_ready():
        return False
    _git(str(BACKUP_DIR), "pull", "--ff-only", "--quiet")
    repo_cfg = _read_json(BACKUP_DIR / "config.json")
    if not repo_cfg:
        return False
    cur = _read_json(CONFIG_FILE)
    merged = dict(cur)
    for k, v in _shareable(repo_cfg).items():
        merged[k] = v
    new = json.dumps(merged, indent=2) + "\n"
    if new == (CONFIG_FILE.read_text() if CONFIG_FILE.exists() else ""):
        return False
    CONFIG_FILE.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(new)
    return True


def push_config() -> int:
    """Outbound sync: write this machine's fleet policy into the config repo and
    push. Commits only if the shareable config actually changed, so a pull-then-push
    (or a re-run) is a clean no-op — that is what keeps the edit→push→pull loop from
    ping-ponging. Every other machine picks it up on its next timer pull."""
    if not _backup_ready():
        print(f"whence: no config repo at {BACKUP_DIR} — run `whence --init-config-repo <git-url>`",
              file=sys.stderr)
        return 2
    _git(str(BACKUP_DIR), "pull", "--ff-only", "--quiet")
    share = _shareable(_read_json(CONFIG_FILE))
    dest = BACKUP_DIR / "config.json"
    new = json.dumps(share, indent=2) + "\n"
    if new == (dest.read_text() if dest.exists() else ""):
        print("config repo already up to date"); return 0
    dest.write_text(new)
    host = host_label()
    stamp = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%d %H:%M UTC")
    _git(str(BACKUP_DIR), "add", "config.json")
    _git(str(BACKUP_DIR), "commit", "--quiet", "-m", f"config: sync from {host} ({stamp})")
    r = _git(str(BACKUP_DIR), "push", "--quiet")
    print("pushed config to the private repo" if r.returncode == 0
          else f"config push FAILED: {r.stderr.strip()}")
    return 0 if r.returncode == 0 else 1


def init_config_repo(url: str) -> int:
    """Clone your PRIVATE config repo into place so pull/push work. Seeds it from
    this machine's current config if the repo is empty. The repo holds only the
    shareable subset (never the machine-local `gh`)."""
    if _backup_ready():
        print(f"whence: config repo already present at {BACKUP_DIR}")
        return 0
    BACKUP_DIR.parent.mkdir(parents=True, exist_ok=True)
    r = sh("git", "clone", "--quiet", url, str(BACKUP_DIR))
    if r.returncode != 0:
        print(f"whence: clone failed: {r.stderr.strip()}", file=sys.stderr); return 1
    dest = BACKUP_DIR / "config.json"
    if not dest.exists():                         # empty repo — seed it from this box
        dest.write_text(json.dumps(_shareable(_read_json(CONFIG_FILE)), indent=2) + "\n")
        _git(str(BACKUP_DIR), "add", "config.json")
        _git(str(BACKUP_DIR), "commit", "--quiet", "-m", f"config: seed from {host_label()}")
        _git(str(BACKUP_DIR), "push", "--quiet")
        print("seeded the config repo from this machine")
    else:
        pull_config()
        print("pulled fleet config from the repo")
    print(f"whence: config repo ready at {BACKUP_DIR}")
    return 0




def _self_clone() -> pathlib.Path:
    here = pathlib.Path(__file__).resolve().parent
    return here if (here / ".git").exists() else (pathlib.Path.home() / ".local/share/whence")


def self_update(force: bool = False) -> bool:
    """Fast-forward this whence clone to origin/main so every machine picks up a
    change made on any other machine — no matter which one made it. Throttled to
    once/day from the hook; reinstalls the agent hook only if the clone moved."""
    clone = _self_clone()
    if not (clone / ".git").exists():
        return False
    if not force and not _throttled("selfupdate", 86400):
        return False
    before = _git(str(clone), "rev-parse", "HEAD").stdout.strip()
    _git(str(clone), "pull", "--ff-only", "--quiet")
    after = _git(str(clone), "rev-parse", "HEAD").stdout.strip()
    if before and after and before != after:
        install_agent_hook("all")
        # hook.sh contains generated wrapper code, not a symlink to this script.
        # Refresh it only for users who already opted into the shell hook.
        if HOOK_FILE.exists():
            install_hook(print_only=False)
        return True
    return False


def deploy() -> int:
    """Push local whence changes, then SSH each host in ~/.config/whence/hosts to
    pull + reinstall — instant propagation from whichever machine you edited on.
    Unreachable hosts are skipped (they self-update on their next stamp)."""
    clone = _self_clone()
    ahead = _git(str(clone), "rev-list", "--count", "@{u}..HEAD").stdout.strip()
    if ahead not in ("", "0"):
        r = _git(str(clone), "push")
        print("pushed local whence changes" if r.returncode == 0 else "local push FAILED")
    if not HOSTS.exists():
        print(f"whence: no host list — add one hostname per line to {HOSTS}")
        return 0
    hosts = [h.strip() for h in HOSTS.read_text().splitlines()
             if h.strip() and not h.lstrip().startswith("#")]
    rc = 0
    for h in hosts:
        remote = ("cd ~/.local/share/whence && git pull --ff-only --quiet && "
                  "./whence --install-agent-hook all >/dev/null 2>&1 && "
                  "{ [ ! -f ~/.config/whence/hook.sh ] || "
                  "./whence --install-hook >/dev/null 2>&1; } && echo whence-ok")
        r = sh("ssh", "-o", "ConnectTimeout=8", h, remote)
        ok = r.returncode == 0 and "whence-ok" in r.stdout
        print(f"  {h}: {'updated' if ok else 'unreachable — will self-update on next stamp'}")
        rc = rc or (0 if ok else 1)
    return rc


