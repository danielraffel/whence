#!/usr/bin/env python3
"""whence — stamp a PR with the provenance of the agent that made it.

Attaches, at PR-open time: prefix-free color-coded labels (agent, machine, cmux
tab) and a visible footer (session id, resume/relaunch commands, restore URL,
jump-to-tab). Works for ANY agent cmux launches — the resume/relaunch handles
come from cmux's own per-tab session-restore, so no agent-specific config is
needed. Every field is toggleable via config.

Usage:
  whence --pr 1234 [--apply]        # default is dry-run (prints only)
  whence --apply                    # find the PR for the current branch
  whence --pr 1234 --hide url,session --apply

Config (all optional, ~/.config/whence/config.json):
  {
    "hide":   ["url"],                 # fields to omit (labels + footer rows)
    "colors": {"agent":"1f6feb", "host":"1a7f37", "tab":"8250df"}
  }
Quick per-run override:  WHENCE_HIDE=url,session   or  --hide url,session
"""
from __future__ import annotations
import argparse, json, os, re, shlex, socket, subprocess, sys, datetime, pathlib, tempfile, time

GH = "gh"                                          # resolved in main: WHENCE_GH env > config "gh" > "gh"
CFG_DIR = pathlib.Path.home() / ".config/whence"

# Fields, in footer order. `agent`/`host`/`tab` are also the queue labels.
# `workspace` = cmux workspace name; `tab` = the per-tab (surface) title you
# navigate by — the one you need most to find your way back.
FIELDS = ["agent", "host", "workspace", "tab", "path", "session", "resume", "url", "jump", "relaunch", "stamped"]
LABEL_FIELDS = ["agent", "host", "workspace", "tab"]
DEFAULT_COLORS = {"agent": "1f6feb", "host": "1a7f37", "workspace": "bf8700", "tab": "8250df"}

# Friendly resume syntax for agents whose CLI we've verified. ANY other agent
# still works via the cmux-sourced `relaunch` command below — this is just for a
# prettier line. Add your agent here (PRs welcome).
KNOWN_RESUME = {"claude": "claude --resume {sid}", "codex": "codex resume {sid}"}
KNOWN_URL = {"claude": "https://claude.ai/code/{bridge}"}

MARK_RE = re.compile(r"<!-- whence( .*?)? -->.*?<!-- /whence -->\n?", re.S)
OLD_PREFIXES = ("agent:", "host:", "ws:")

# The command's OUTPUT names its own outcome — the PR URL that `gh`/`shipyard`
# print, or the `To github.com:owner/repo.git` + refspec that `git push` prints.
# That is the ONLY cwd-independent source of truth we get. Inferring the repo and
# branch from the hook's cwd instead is what silently drops PRs: an agent hook
# runs in the SESSION's project root, which is NOT the worktree the command ran
# in, so anything shipped from a worktree resolved the wrong branch and no-op'd.
# Reading the output works no matter what shells out to what — gh, shipyard, pulp,
# a bare `git push`, a script — because they all have to print where the code went.
PR_URL_RE = re.compile(r"https://github\.com/([\w.-]+/[\w.-]+?)(?:\.git)?/pull/(\d+)\b")
NEW_PR_RE = re.compile(r"https://github\.com/([\w.-]+/[\w.-]+?)(?:\.git)?/pull/new/(\S+)")
PUSH_TO_RE = re.compile(r"^To (?:(?:\w+://)?(?:[\w.-]+@)?github\.com[:/])"
                        r"([\w.-]+/[\w.-]+?)(?:\.git)?/?$", re.M)
# `   abc1234..def5678  fix/x -> fix/x`, ` * [new branch]  fix/x -> fix/x`,
# ` + 999f...888e  fix/x -> fix/x (forced update)` — the trailing note is optional.
REFSPEC_RE = re.compile(r"^[\s+*-]*(?:\[new branch\]|\[new tag\]|[0-9a-f]{4,}\.{2,3}[0-9a-f]{4,})"
                        r"\s+(\S+)\s+->\s+(\S+?)(?:\s+\(.*\))?\s*$", re.M)


def _tool_response_text(payload: dict) -> str:
    tr = payload.get("tool_response") or payload.get("toolResponse") or ""
    if isinstance(tr, dict):
        return "\n".join(str(tr.get(k) or "")
                         for k in ("stdout", "stderr", "output", "content"))
    return tr if isinstance(tr, str) else str(tr)


def parse_outcome(payload: dict) -> tuple[str, str, str]:
    """(repo_slug, branch, pr_number) as reported by the command itself.

    Any field may be "" — a `git push` names a repo+branch but no PR (the PR may
    not exist yet); a `gh pr create` names a repo+PR directly. Reads stdout AND
    stderr: git writes its refspec summary to stderr."""
    tr = _tool_response_text(payload)
    slug = branch = pr = ""
    m = PR_URL_RE.search(tr)
    if m:
        slug, pr = m.group(1), m.group(2)
    if not slug:
        m = NEW_PR_RE.search(tr) or PUSH_TO_RE.search(tr)
        if m:
            slug = m.group(1)
            if m.re is NEW_PR_RE:
                branch = m.group(2)
    if slug and not branch:
        # Gated on `slug`: a refspec with no GitHub repo above it came from some
        # OTHER remote, and pairing that branch with a cwd-derived GitHub slug
        # would file the entry under a repo the push never touched.
        m = REFSPEC_RE.search(tr)
        if m and m.group(2) != "HEAD":
            branch = m.group(2)
            if branch.startswith("refs/heads/"):
                branch = branch[len("refs/heads/"):]
    return slug, branch, pr


def pushed_source_ref(payload: dict) -> str:
    """The local source ref named by a successful push summary, if present."""
    m = REFSPEC_RE.search(_tool_response_text(payload))
    return m.group(1) if m else ""


# The whole config, every knob shown at its default. `whence --init` writes this.
# Flip any field false to drop it; set labels/footer false to drop a whole surface;
# set repos.mode to "allow"/"deny" with a list to scope which repos get stamped.
DEFAULT_CONFIG = {
    "fields": {f: True for f in FIELDS},
    "labels": True,
    "footer": True,
    "colors": dict(DEFAULT_COLORS),
    "repos": {"mode": "all", "list": []},
    "gh": "gh",
    "label_maxlen": 24,
    # Names we must never publish — a cmux tab/workspace title that contains any of
    # these (case-insensitive substring) is replaced before it can become a PR
    # label or appear in the footer. Seed it with whatever your repo can't carry:
    # vendor/framework names, code names, an unreleased product. cmux derives tab
    # titles from the agent's prompt, so a title like "port the AcmeSynth reverb" would
    # otherwise land verbatim on a public PR. We can't rename a cmux tab (no such
    # API), so redaction at publish time is the only enforcement.
    "denylist": [],
    "redact_placeholder": "(redacted)",
    # Append a JSONL line to ~/.config/whence/audit.jsonl on every label CHANGE
    # (who/source/when + before -> after). Off by default; a debug switch you flip
    # on to validate behavior, then off. `whence --log` reads it back.
    "audit_log": False,
    # Prefix labels with 1·/2·/3·/4· so the PR-list view (which sorts chips
    # alphabetically) renders them agent -> host -> workspace -> tab. The footer
    # table already shows this order and stays clean; only the chips get the prefix.
    "order_labels": False,
}


def sh(*a, **k):
    # Bounded + graceful: a missing binary (e.g. no cmux) or a slow network call
    # degrades to an empty result instead of crashing or hanging the caller.
    k.setdefault("timeout", 15)
    try:
        return subprocess.run(a, capture_output=True, text=True, **k)
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError) as e:
        return subprocess.CompletedProcess(a, 1, "", str(e))


def load_config(cli_hide: str) -> dict:
    # footer/labels default ON; either can be turned off globally or per-run.
    cfg = {"hide": set(), "colors": dict(DEFAULT_COLORS), "repos": {},
           "footer": True, "labels": True, "gh": "", "label_maxlen": 24,
           "denylist": [], "redact_placeholder": "(redacted)", "audit_log": False,
           "order_labels": False}
    f = CFG_DIR / "config.json"
    if f.exists():
        try:
            d = json.loads(f.read_text())
        except Exception as e:
            print(f"whence: ignoring bad config.json: {e}", file=sys.stderr)
            d = {}
        if not isinstance(d, dict):
            d = {}
        # Each field is read independently — a single bad value keeps that field's
        # default instead of discarding the whole config.
        def field(key, apply):
            if key in d:
                try: apply(d[key])
                except Exception: print(f"whence: ignoring bad config field '{key}'", file=sys.stderr)
        field("hide", lambda v: cfg["hide"].update(set(v)))
        field("colors", lambda v: cfg["colors"].update(v))
        field("repos", lambda v: cfg.__setitem__("repos", v if isinstance(v, dict) else cfg["repos"]))
        field("footer", lambda v: cfg.__setitem__("footer", bool(v)))
        field("labels", lambda v: cfg.__setitem__("labels", bool(v)))
        field("gh", lambda v: cfg.__setitem__("gh", str(v or "")))
        field("label_maxlen", lambda v: cfg.__setitem__("label_maxlen", int(v)))
        field("denylist", lambda v: cfg.__setitem__(
            "denylist", [str(x).lower() for x in v if str(x).strip()]))
        field("redact_placeholder", lambda v: cfg.__setitem__("redact_placeholder", str(v)))
        field("audit_log", lambda v: cfg.__setitem__("audit_log", bool(v)))
        field("order_labels", lambda v: cfg.__setitem__("order_labels", bool(v)))
        # "fields": {"host": false, ...} — the easy per-field on/off switch.
        field("fields", lambda v: [cfg["hide"].add(n) for n, on in v.items() if not on])
    for src in (os.environ.get("WHENCE_HIDE", ""), cli_hide or ""):
        cfg["hide"] |= {x.strip() for x in src.split(",") if x.strip()}
    unknown = cfg["hide"] - set(FIELDS)
    if unknown:
        print(f"whence: unknown hide field(s) ignored: {', '.join(sorted(unknown))} "
              f"(valid: {', '.join(FIELDS)})", file=sys.stderr)
    return cfg


def host_label() -> str:
    raw = socket.gethostname().split(".")[0]
    label = os.environ.get("WHENCE_HOST_LABEL", "").strip()
    if not label:
        f = CFG_DIR / "host-label"
        if f.exists():
            label = f.read_text().strip()
    return label or raw


import unicodedata


def clean_title(t: str) -> str:
    """Strip cmux's leading status glyphs — spinner braille (⠙⠦⠐…), run/err/dirty
    emoji (🏃 ❌ ✳ …), and separators — leaving the human tab name."""
    i = 0
    while i < len(t):
        ch = t[i]
        if (ch.isspace() or unicodedata.category(ch).startswith("S")
                or 0x2800 <= ord(ch) <= 0x28FF or ord(ch) >= 0x1F000):
            i += 1
            continue
        break
    return t[i:].strip()


def cmux_workspace(ws_id: str) -> str:
    """The workspace name — ONLY when you gave it a custom title.

    cmux auto-titles an unnamed workspace from one of the agent tabs inside it, so
    the auto-title IS some tab's title — at best redundant with the tab label, at
    worst a DIFFERENT tab's name sitting under a "workspace" label. Unnamed means
    no workspace label; naming a workspace is what opts you into one, and its
    presence then tells you the workspace was named deliberately."""
    if not ws_id:
        return ""
    r = sh("cmux", "rpc", "workspace.list")
    if r.returncode == 0:
        try:
            for w in json.loads(r.stdout).get("workspaces", []):
                if w.get("id") == ws_id:
                    if w.get("has_custom_title") and w.get("custom_title"):
                        return clean_title(w["custom_title"])
                    break
        except Exception:
            pass
    return ""


def cmux_tab_title(surface_id: str) -> tuple[str, str]:
    """The per-tab (surface) title — the name you navigate by — plus its cmux
    ref (e.g. `surface:13`) ONLY when another tab shares the same title (so two
    "pulp" tabs are tellable apart, but unique names stay clean). JSON-driven
    from `cmux rpc surface.list`; re-running whence re-reads the current title."""
    if not surface_id:
        return "", ""
    r = sh("cmux", "rpc", "surface.list")
    if r.returncode == 0:
        try:
            surfaces = json.loads(r.stdout).get("surfaces", [])
            counts, mine = {}, None
            for s in surfaces:
                t = clean_title(s.get("title") or "")
                counts[t] = counts.get(t, 0) + 1
                if s.get("id") == surface_id:
                    mine = (t, s.get("ref") or "")
            if mine:
                t, ref = mine
                return t, (ref if t and counts.get(t, 0) > 1 else "")
        except Exception:
            pass
    return "", ""


def _surface_ref(surface_id: str) -> str:
    """This surface's cmux ref (`surface:16`) — a stable, name-free handle we can
    show when the real title can't be published. Navigation never needs the title:
    the footer's jump command uses the surface UUID regardless."""
    if not surface_id:
        return ""
    r = sh("cmux", "rpc", "surface.list")
    if r.returncode == 0:
        try:
            for sfc in json.loads(r.stdout).get("surfaces", []):
                if sfc.get("id") == surface_id:
                    return sfc.get("ref") or ""
        except Exception:
            pass
    return ""


def denied(value: str, cfg: dict) -> str:
    """The first denylist term `value` contains (case-insensitive substring), or "".

    Substring, not word-boundary, and fail-closed: a title that merely embeds a
    denied token is redacted. Over-redacting a legitimate title is a cosmetic
    annoyance; leaking a name you promised never to publish is not."""
    low = (value or "").lower()
    for term in cfg.get("denylist", []):
        if term and term in low:
            return term
    return ""


def scrub_denied(value: str, cfg: dict) -> str:
    """Cut the denied TERMS out of a name, keeping the rest: with `juce` denied,
    "Improve JUCE import" -> "Improve import". Tidies the whitespace and dangling
    separators the removal leaves behind. Returns "" if nothing meaningful is left
    (e.g. the whole title WAS the denied word) so the caller can fall back to a
    name-free handle."""
    out = value or ""
    for term in cfg.get("denylist", []):
        if term:
            out = re.sub(re.escape(term), " ", out, flags=re.IGNORECASE)
    out = re.sub(r"\s*[-/:_|·]+\s*", " ", out)   # separators orphaned by the cut
    out = re.sub(r"\s{2,}", " ", out).strip(" -/:_|·\t")
    return out.strip()


def redact(p: dict, cfg: dict, surface_id: str = "") -> list[str]:
    """Scrub any free-form NAME field (tab, workspace) that trips the denylist, in
    place, before it can reach a label or the public footer. Removes just the
    forbidden term where a readable name survives; falls back to a name-free cmux
    ref (tab) or the placeholder (workspace) only when nothing usable is left.
    Returns the fields it touched. The opaque provenance — session id, resume
    command, jump/relaunch UUIDs — is never a name and is left intact."""
    hit = []
    if not cfg.get("denylist"):
        return hit
    placeholder = cfg.get("redact_placeholder", "(redacted)")
    for f in ("tab", "workspace"):
        if denied(p.get(f, ""), cfg):
            scrubbed = scrub_denied(p[f], cfg)
            if scrubbed and len(scrubbed) >= 2 and not denied(scrubbed, cfg):
                p[f] = scrubbed
            else:
                p[f] = (_surface_ref(surface_id) or placeholder) if f == "tab" else placeholder
            hit.append(f)
    if denied(p.get("path", ""), cfg):          # a worktree named after a denied term
        p["path"] = scrub_denied(p["path"], cfg) or "~"
        hit.append("path")
    return hit


def sanitize_path(path: str, cfg: dict) -> str:
    """The working directory, safe to publish: the private home prefix collapses
    to `~` (so no username leaks) and any denied term is scrubbed out — but the
    folder itself is kept, because that's what you need to find the worktree again.
    `/Users/me/Code/pulp-x` -> `~/Code/pulp-x`."""
    pth = path or ""
    home = os.path.expanduser("~")
    if home and (pth == home or pth.startswith(home + "/")):
        pth = "~" + pth[len(home):]
    if denied(pth, cfg):
        scrubbed = scrub_denied(pth, cfg)
        pth = scrubbed if scrubbed else "~"
    return pth


def collect(cfg: dict | None = None) -> dict:
    agent = os.environ.get("CMUX_AGENT_LAUNCH_KIND") or (
        "claude" if os.environ.get("CLAUDECODE") else
        "codex" if os.environ.get("CODEX_SESSION_ID") or os.environ.get("CODEX_ROLLOUT_ID") else
        "unknown")
    surface = os.environ.get("CMUX_SURFACE_ID", "")
    p = {f: "" for f in FIELDS}
    p["_redacted"] = []
    p["agent"] = agent
    p["host"] = host_label()
    p["workspace"] = cmux_workspace(os.environ.get("CMUX_WORKSPACE_ID", ""))
    tab, ref = cmux_tab_title(surface)
    if tab:
        p["tab"] = f"{tab} ({ref})" if ref else tab
    else:
        # cmux shows only a status glyph (🏃/spinner) while the agent is busy, which
        # cleans to empty exactly when a PR is opened. A name-free ref beats a blank
        # label, and the sweep upgrades it to the real name once the title settles.
        p["tab"] = _surface_ref(surface)
    p["stamped"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%d %H:%M UTC")
    p["path"] = sanitize_path(os.getcwd(), cfg if cfg is not None else load_config(""))

    restore = ""
    if surface:
        r = sh("cmux", "surface", "resume", "get", "--surface", surface)
        if r.returncode == 0:
            restore = r.stdout.strip()
        p["jump"] = f"cmux surface focus {surface}"
        p["relaunch"] = f"cmux surface resume get --surface {surface}"  # exact cmd, any agent

    # Session id must be CONSISTENT with the detected agent — never pair claude's
    # session with codex's resume syntax (or vice versa) if both env vars leak in.
    if agent == "claude":
        sid = os.environ.get("CLAUDE_CODE_SESSION_ID", "")
    elif agent == "codex":
        sid = os.environ.get("CODEX_SESSION_ID") or os.environ.get("CODEX_ROLLOUT_ID") or ""
    else:
        sid = (os.environ.get("CLAUDE_CODE_SESSION_ID")
               or os.environ.get("CODEX_SESSION_ID") or os.environ.get("CODEX_ROLLOUT_ID") or "")
    if not sid and restore:
        m = re.search(r"[0-9a-fA-F]{8}-[0-9a-fA-F-]{27}", restore)
        sid = m.group(0) if m else ""
    p["session"] = sid

    if agent in KNOWN_RESUME and sid:
        p["resume"] = KNOWN_RESUME[agent].format(sid=sid)
    if agent in KNOWN_URL:
        bridge = os.environ.get("CLAUDE_CODE_BRIDGE_SESSION_ID", "")
        if bridge:
            p["url"] = KNOWN_URL[agent].format(bridge=bridge)
    p["_redacted"] = redact(p, cfg if cfg is not None else load_config(""), surface)
    return p


def visible(field: str, p: dict, hide: set) -> bool:
    return field not in hide and bool(p.get(field))


def _clip(s: str, n: int) -> str:
    """Shorten a label to ~n chars, ending with … — long tab/workspace names make
    unreadable queue chips. Prefers a whole-word break (may fall a little short of
    n rather than cut mid-word), but hard-caps a runaway single word so nothing
    blows past the limit. The full name always lives in the footer."""
    s = s.strip()
    if n <= 0 or len(s) <= n:
        return s[:50]  # GitHub's hard label max
    budget = max(1, n - 1)                       # leave room for the …
    head = s[:budget]
    sp = head.rfind(" ")
    if sp >= int(budget * 0.6):                  # a word break close enough to keep
        head = head[:sp]
    return head.rstrip() + "…"


def labels_for(p: dict, cfg: dict) -> list[tuple[str, str]]:
    # GitHub's PR-LIST view sorts label chips ALPHABETICALLY by name (verified in a
    # browser — it ignores add-order AND creation-id there). So the only way to force
    # agent -> host -> workspace -> tab in the queue is a numeric sort-prefix on the
    # name. Opt-in via `order_labels`; the raw value still shows clean in the footer.
    out = []
    order = cfg.get("order_labels")
    for i, f in enumerate(LABEL_FIELDS):
        if visible(f, p, cfg["hide"]):
            name = _clip(p[f], cfg.get("label_maxlen", 24))
            if order:
                name = f"{i + 1}\u00b7{name}"          # 1·  2·  3·  4·
            out.append((name, cfg["colors"].get(f, "ededed")))
    return out


def footer(p: dict, cfg: dict, label_names: list[str]) -> str:
    hide = cfg["hide"]
    # Carry the agent + tab that were actually stamped, so the sweep can tell a
    # good stamp from a degraded one (blank/ref tab, unknown agent) without
    # re-deriving it from the labels.
    tag = json.dumps({"labels": label_names,
                      "prov": {"agent": p.get("agent", ""), "tab": p.get("tab", "")}},
                     ensure_ascii=False)
    def cell(v):                              # keep a value from breaking the table
        return (v or "").replace("|", "\\|").replace("\n", " ")
    # identity, as a two-column table in agent -> host -> workspace -> tab order
    # (the one place we CAN control order; GitHub sorts the label chips itself).
    trows = []
    for f, lbl, code in [("agent", "Agent", True), ("host", "Machine", True),
                         ("workspace", "Workspace", True), ("tab", "Tab", False),
                         ("path", "Directory", True), ("session", "Session", True)]:
        if visible(f, p, hide):
            val = f"`{cell(p[f])}`" if code else cell(p[f])
            trows.append(f"| **{lbl}** | {val} |")
    table = ("|  |  |\n|:--|:--|\n" + "\n".join(trows)) if trows else ""
    # the commands you actually copy: fenced blocks so GitHub renders a copy button
    # on each (inline code has none). One tap instead of a fiddly text selection.
    blocks = []
    for f, lbl in [("resume", "Resume"), ("jump", "Jump to this tab"),
                   ("relaunch", "Relaunch (any agent)")]:
        if visible(f, p, hide):
            blocks.append(f"**{lbl}**\n```\n{p[f]}\n```")
    if visible("url", p, hide):
        blocks.append(f"**Restore URL** — {p['url']}")
    tail = f"\n\n<sub>stamped {p['stamped']}</sub>" if visible("stamped", p, hide) else ""
    body = "\n\n".join(x for x in (table, "\n".join(blocks)) if x) + tail
    return f"<!-- whence {tag} -->\n\n---\n### 🔎 Provenance\n\n{body}\n<!-- /whence -->"


def resolve_pr(args) -> str:
    if args.pr:
        return str(args.pr)
    br = args.branch or sh("git", "rev-parse", "--abbrev-ref", "HEAD").stdout.strip()
    return sh(GH, "pr", "view", br, "--json", "number", "-q", ".number").stdout.strip()


def repo_allowed(cfg: dict, slug: str = "") -> bool:
    """Per-repo enable/disable. Two ways, either turns it off here:
    1. Drop a `.whence-off` file in the repo root  →  disabled in that repo.
    2. Global list in config: "repos": {"mode":"allow"|"deny","list":["owner/repo"]}.

    `slug` is the repo the COMMAND touched. Pass it whenever it's known: resolving
    the repo from the cwd instead would apply repo A's allow/deny rule to a PR in
    repo B (the hook's cwd is the session root, not where the command ran)."""
    top = sh("git", "rev-parse", "--show-toplevel").stdout.strip()
    if top and (pathlib.Path(top) / ".whence-off").exists() and not slug:
        return False
    r = cfg.get("repos") or {}
    mode = r.get("mode", "all")
    if mode == "all":
        return True
    slug = slug or sh(GH, "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner").stdout.strip()
    lst = set(r.get("list", []))
    if mode == "allow":
        return slug in lst
    if mode == "deny":
        return slug not in lst
    return True


# The one cross-agent trigger: wrap the command that opens the PR. Every agent
# shells out to one of these, so a shell function catches them all — no per-agent
# hook or Shipyard integration required. The long-running orchestrators capture
# before launch; every tool still runs the idempotent post-command stamp.
PR_TOOLS = {
    "shipyard": '[ "$1" = pr ]',
    "pulp":     '[ "$1" = pr ]',
    "gh":       '[ "$1" = pr ] && [ "$2" = create ]',
    "ghapp":    '[ "$1" = pr ] && [ "$2" = create ]',
}
PREEXEC_TOOLS = {"shipyard", "pulp"}
HOOK_MARK_RE = re.compile(r"\n*# >>> whence hook >>>.*?# <<< whence hook <<<\n", re.S)
HOOK_FILE = CFG_DIR / "hook.sh"


def _hook_source_block() -> str:
    return ("# >>> whence hook >>>  (managed by `whence --install-hook`; safe to delete)\n"
            f'[ -f "{HOOK_FILE}" ] && . "{HOOK_FILE}"\n'
            "# <<< whence hook <<<\n")


def _hook_file_text() -> tuple[str, list]:
    """Build the sourced functions file. A shell FUNCTION beats PATH lookup in
    EVERY shell mode (interactive or not), so — unlike a PATH-dir shim — it can't
    be shadowed by a later .zshrc reordering PATH. Each function runs the REAL
    tool via `command` (which skips functions → no recursion, and no double-stamp
    when one tool internally spawns another), then stamps best-effort."""
    from shutil import which
    tools = [(t, trig) for t, trig in PR_TOOLS.items() if which(t)]
    lines = [
        "# whence hook — sourced by your shell init. Thin wrappers around the",
        "# PR-opening commands that stamp the branch's PR right after it opens.",
        "# A function beats PATH, so this fires regardless of PATH order; `command`",
        "# runs the real tool (no recursion); the stamp never changes the exit code.",
        "# NB: `command whence` — plain `whence` is a zsh BUILTIN (like `which`), so",
        "# `command` is required to reach this script rather than the builtin.",
        "__whence_stamp() { command whence --auto >/dev/null 2>&1 || true; }",
        "__whence_preexec() { command whence --pre-exec \"$PWD\" >/dev/null 2>&1 || true; }",
        "__whence_will_act() { for __whence_arg in \"$@\"; do case \"$__whence_arg\" in "
        "-h|--help|--version|--dry-run) return 1;; esac; done; return 0; }",
    ]
    for tool, trig in tools:
        active = f"{trig} && __whence_will_act \"$@\""
        before = f"if {active}; then __whence_preexec; fi; " if tool in PREEXEC_TOOLS else ""
        lines.append(
            f'{tool}() {{ {before}command {tool} "$@"; __whence_rc=$?; '
            f"if {active}; then __whence_stamp; fi; return $__whence_rc; }}")
    return "\n".join(lines) + "\n", [t for t, _ in tools]


def install_hook(print_only: bool) -> int:
    """Install (or print) the shell-function hook that stamps every future PR at
    open time, for any agent, without depending on Shipyard."""
    text, tools = _hook_file_text()
    block = _hook_source_block()
    if print_only:
        print(f"# hook file: {HOOK_FILE}")
        print(f"# wraps: {', '.join(tools) or '(no PR tool found on PATH)'}")
        print("\n# ---- hook.sh ----\n" + text)
        print("# add to ~/.zshenv (and ~/.bashrc if you use bash):\n" + block)
        return 0
    if not tools:
        print("whence: found no PR tool (shipyard/pulp/gh/ghapp) on PATH — nothing to wrap.\n"
              "  Install one, or wire an agent hook instead (see the README).", file=sys.stderr)
        return 1
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    HOOK_FILE.write_text(text)
    targets = [pathlib.Path(os.path.expanduser("~/.zshenv"))]  # always: universal zsh init
    bashrc = pathlib.Path(os.path.expanduser("~/.bashrc"))
    if bashrc.exists():
        targets.append(bashrc)
    for rcp in targets:
        cur = rcp.read_text() if rcp.exists() else ""
        cur = HOOK_MARK_RE.sub("\n", cur).rstrip()
        rcp.write_text((cur + "\n\n" + block) if cur else block)
    print(f"whence: wrote hook {HOOK_FILE}")
    print(f"  wraps: {', '.join(tools)}")
    print("  sourced from: " + ", ".join(str(t) for t in targets))
    print("Open a new shell/tab (or `source ~/.zshenv`) to activate. "
          "Every PR opened after that self-stamps.")
    return 0


def uninstall_hook() -> int:
    """Remove the hook file and the sourcing block — full reversal of --install-hook."""
    existed = HOOK_FILE.exists()
    if existed:
        HOOK_FILE.unlink()
    for rc in ("~/.zshenv", "~/.bashrc"):
        rcp = pathlib.Path(os.path.expanduser(rc))
        if not rcp.exists():
            continue
        cur = rcp.read_text()
        new = HOOK_MARK_RE.sub("\n", cur)
        new = new.rstrip() + "\n" if new.strip() else ""
        if new != cur:
            rcp.write_text(new)
    print(f"whence: removed hook {'file' if existed else '(none)'} and the sourcing block.")
    print("Open a new shell/tab for it to take full effect.")
    return 0


PR_HOOK = CFG_DIR / "pr-hook.sh"


def _write_pr_hook() -> pathlib.Path:
    """Write the tiny stdin shim an agent's PostToolUse hook runs. It just pipes
    the tool JSON into `whence --hook` (all parsing/matching happens in-process,
    so there's no fragile shell quoting). whence is called by absolute path
    because plain `whence` is a zsh builtin."""
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    whence_bin = os.path.realpath(sys.argv[0])
    PR_HOOK.write_text(
        "#!/bin/sh\n"
        "# whence agent PR hook — an agent PostToolUse hook pipes the tool-call JSON\n"
        "# to this on stdin. A cheap shell pre-filter avoids starting Python on the\n"
        "# ~99% of commands that clearly aren't a PR-open; whence --hook then does\n"
        "# the precise check (command field, not the whole payload) and stamps.\n"
        "# Always exits 0 so a stamping hiccup never breaks the agent.\n"
        "in=$(cat 2>/dev/null)\n"
        "# match only the command (in tool_input, before tool_response) — never the\n"
        "# command's OUTPUT — so a command whose output mentions a PR verb is ignored.\n"
        "# `git push` MUST be here: a push is how a PR the daemon opens later gets\n"
        "# its branch into the ledger, and dropping it here silently killed that.\n"
        'head=${in%%\\"tool_response\\"*}\n'
        "case \"$head\" in\n"
        "  *\"pr create\"*|*\"shipyard pr\"*|*\"pulp pr\"*|*\"git push\"*)\n"
        f'    printf \'%s\' "$in" | "{whence_bin}" --hook || true ;;\n'
        "esac\n"
        "exit 0\n")
    PR_HOOK.chmod(0o755)
    return PR_HOOK


def _wire_posttooluse(path: pathlib.Path, matcher: str, extra: dict) -> None:
    """Idempotently add a PostToolUse entry pointing at pr-hook.sh to a Claude/
    Codex-style hooks JSON (they share the schema)."""
    d = {}
    if path.exists():
        try: d = json.loads(path.read_text())
        except Exception: d = {}
    ptu = d.setdefault("hooks", {}).setdefault("PostToolUse", [])
    cmd = str(PR_HOOK)
    def has(e): return any(x.get("command", "").endswith("pr-hook.sh") for x in e.get("hooks", []))
    mine = [e for e in ptu if e.get("matcher") == matcher or has(e)]
    entry = {"type": "command", "command": cmd, **extra}
    if any(has(e) for e in ptu):
        for e in ptu:
            if has(e):
                e["hooks"] = [x for x in e["hooks"] if not x.get("command", "").endswith("pr-hook.sh")] + [entry]
    elif mine:
        mine[0].setdefault("hooks", []).append(entry)
    else:
        ptu.append({"matcher": matcher, "hooks": [entry]})
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(d, indent=2) + "\n")


def install_agent_hook(scope: str) -> int:
    """Wire the reliable in-process agent hooks: Claude globally, Codex per-repo
    (Codex only reads a repo's own .codex/hooks.json, and gates it behind trust)."""
    _write_pr_hook()
    did = []
    if scope in ("all", "claude"):
        _wire_posttooluse(pathlib.Path(os.path.expanduser("~/.claude/settings.json")),
                          "Bash", {})
        did.append("claude (~/.claude/settings.json, global)")
    if scope in ("all", "codex"):
        _wire_posttooluse(pathlib.Path(os.path.expanduser("~/.codex/hooks.json")),
                          "Bash|Shell|shell|local_shell|exec", {"timeout": 20000})
        did.append("codex (~/.codex/hooks.json, global)")
    print(f"whence: wrote {PR_HOOK}")
    for d in did:
        print(f"  wired {d}")
    if scope in ("all", "codex"):
        print("\nCodex note: this is Codex's GLOBAL hooks file — it applies to every repo,\n"
              "no per-repo install. Codex gates hooks behind trust, so it will ask you to\n"
              "trust the whence hook once on its next run.")
    return 0


SWEEP_PLIST = pathlib.Path(os.path.expanduser(
    "~/Library/LaunchAgents/com.whence.sweep.plist"))
SWEEP_EVERY = 600


CONFIG_WATCH_PLIST = pathlib.Path(os.path.expanduser(
    "~/Library/LaunchAgents/com.whence.config-push.plist"))


def install_config_watch(uninstall: bool = False) -> int:
    """Push your config edit to the private repo the instant you save it — a launchd
    WatchPaths agent on config.json runs `whence --push-config`. Other machines pull
    it on their sweep tick. Loop-safe: push commits only when the shareable config
    changed, so a pull-driven write that fires this agent finds nothing to commit
    and stops. macOS only (elsewhere: run `whence --push-config` after editing)."""
    label = "com.whence.config-push"
    if sys.platform != "darwin":
        print("whence: not macOS — run `whence --push-config` after editing config")
        return 0
    if uninstall:
        sh("launchctl", "bootout", f"gui/{os.getuid()}/{label}")
        if CONFIG_WATCH_PLIST.exists():
            CONFIG_WATCH_PLIST.unlink()
        print("whence: removed the config-push watcher")
        return 0
    if not _backup_ready():
        print(f"whence: no config repo — run `whence --init-config-repo <git-url>` first",
              file=sys.stderr)
        return 1
    whence_bin = os.path.realpath(sys.argv[0])
    path = ":".join([os.path.expanduser("~/.local/bin"), "/opt/homebrew/bin",
                     "/usr/local/bin", "/usr/bin", "/bin"])
    CONFIG_WATCH_PLIST.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_WATCH_PLIST.write_text(f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>{label}</string>
  <key>ProgramArguments</key>
  <array><string>{sys.executable}</string><string>{whence_bin}</string><string>--push-config</string></array>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>{path}</string></dict>
  <key>WatchPaths</key><array><string>{CONFIG_FILE}</string></array>
  <key>ProcessType</key><string>Background</string>
</dict>
</plist>
""")
    sh("launchctl", "bootout", f"gui/{os.getuid()}/{label}")
    r = sh("launchctl", "bootstrap", f"gui/{os.getuid()}", str(CONFIG_WATCH_PLIST))
    if r.returncode != 0:
        print(f"whence: could not load the config-push watcher: {r.stderr.strip()}",
              file=sys.stderr)
        return 1
    print(f"whence: config-push watcher armed ({CONFIG_WATCH_PLIST})")
    print("  edits to config.json now push to the private repo automatically")
    return 0


def install_sweep(uninstall: bool = False) -> int:
    """Run the sweep on a timer instead of only when an agent happens to fire the
    hook again.

    Without this, the LAST PR of a session is never swept: the hook's sweep is
    opportunistic (it piggybacks on the next push/PR command in that shell), so a
    session that opens a PR and stops leaves it unstamped forever. macOS only —
    elsewhere, add `whence --sweep` to cron (the sweep is idempotent and, once
    entries are marked done, costs no API calls)."""
    if sys.platform != "darwin":
        print(f"whence: not macOS — add this to cron instead:\n"
              f"  */{SWEEP_EVERY // 60} * * * * {os.path.realpath(sys.argv[0])} --sweep")
        return 0
    label = "com.whence.sweep"
    if uninstall:
        sh("launchctl", "bootout", f"gui/{os.getuid()}/{label}")
        if SWEEP_PLIST.exists():
            SWEEP_PLIST.unlink()
        print("whence: removed the sweep timer")
        return 0
    whence_bin = os.path.realpath(sys.argv[0])
    # launchd starts with a bare PATH; gh/ghapp/git live in the user's dirs.
    path = ":".join([os.path.expanduser("~/.local/bin"), "/opt/homebrew/bin",
                     "/usr/local/bin", "/usr/bin", "/bin", "/usr/sbin", "/sbin"])
    SWEEP_PLIST.parent.mkdir(parents=True, exist_ok=True)
    SWEEP_PLIST.write_text(f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>{label}</string>
  <key>ProgramArguments</key>
  <array><string>{sys.executable}</string><string>{whence_bin}</string><string>--sweep</string></array>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>{path}</string></dict>
  <key>StartInterval</key><integer>{SWEEP_EVERY}</integer>
  <key>RunAtLoad</key><true/>
  <key>ProcessType</key><string>Background</string>
</dict>
</plist>
""")
    sh("launchctl", "bootout", f"gui/{os.getuid()}/{label}")
    r = sh("launchctl", "bootstrap", f"gui/{os.getuid()}", str(SWEEP_PLIST))
    if r.returncode != 0:
        print(f"whence: could not load the sweep timer: {r.stderr.strip()}", file=sys.stderr)
        return 1
    print(f"whence: sweep timer every {SWEEP_EVERY // 60}m ({SWEEP_PLIST})")
    return 0


def _best_gh() -> str:
    """Pick the GitHub CLI to use for whence's own calls: gh if present, else
    ghapp (App-token). Lets machines that only have ghapp work with zero config."""
    from shutil import which
    return "gh" if which("gh") else ("ghapp" if which("ghapp") else "gh")


def setup(host: str | None) -> int:
    """One-shot guided setup: name the machine, write the config (auto-picking the
    GitHub CLI), and install the every-future-PR hook. Reports what it will catch."""
    from shutil import which
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    hf = CFG_DIR / "host-label"
    if host and host.strip():
        hf.write_text(host.strip() + "\n"); hs = host.strip()
    elif hf.exists() and hf.read_text().strip():
        hs = hf.read_text().strip()
    else:
        hs = socket.gethostname().split(".")[0]
        hf.write_text(hs + "\n")
    cf = CFG_DIR / "config.json"
    cfg = dict(DEFAULT_CONFIG)
    if cf.exists():
        try: cfg = json.loads(cf.read_text())
        except Exception: pass
    # Auto-pick the GitHub CLI unless the user already set a non-default one.
    if not cfg.get("gh") or cfg.get("gh") == "gh":
        cfg["gh"] = _best_gh()
    cf.write_text(json.dumps(cfg, indent=2) + "\n")

    print(f"whence setup")
    print(f"  machine label : {hs}   ({hf})")
    print(f"  github CLI    : {cfg['gh']}   (for whence's own calls)")
    print(f"  config        : {cf}")
    have = [t for t in PR_TOOLS if which(t)]
    print(f"  will catch PRs opened via: {', '.join(have) or '(none found — install gh/ghapp/shipyard/pulp)'}")
    print()
    rc = install_hook(print_only=False)
    print()
    install_agent_hook("all")   # the in-process hook: sees worktrees the shell can't
    print()
    install_sweep()             # the backstop: catches whatever both hooks missed
    print("\nSetup complete. New PRs from this machine self-stamp once you open a fresh shell/tab.")
    return rc


def resync() -> int:
    """Refresh THIS tab's open PRs with the current name — on demand, no tracking.
    Each PR whence stamped carries this tab's stable surface id in its footer, so
    we just search open PRs for it and re-stamp (idempotent). Run it after you
    rename a tab; nothing monitors in the background."""
    surface = os.environ.get("CMUX_SURFACE_ID", "")
    if not surface:
        print("whence: no CMUX_SURFACE_ID in this shell — can't identify this tab's PRs",
              file=sys.stderr)
        return 2
    r = sh(GH, "pr", "list", "--state", "open", "--search", surface,
           "--json", "number", "-q", ".[].number")
    nums = [x for x in r.stdout.split() if x.strip()]
    if not nums:
        print("whence: no open PRs stamped from this tab — nothing to resync")
        return 0
    print(f"whence: refreshing {len(nums)} open PR(s) from this tab: "
          + ", ".join("#" + n for n in nums))
    self = os.path.realpath(sys.argv[0])
    for n in nums:
        sh(sys.executable, self, "--pr", n, "--apply")
        print(f"  #{n} refreshed")
    return 0


