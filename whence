#!/usr/bin/env python3
"""whence — stamp a PR with the provenance of the agent that made it.

Attaches, at PR-open time: prefix-free color-coded labels (agent, machine, cmux
tab) and a visible footer (session id, resume/relaunch commands, restore URL,
jump-to-tab). Works for ANY agent cmux launches — the resume/relaunch handles
come from cmux's own per-tab session-restore, so no agent-specific config is
needed. Every field is toggleable via config.

Usage:
  whence --pr 1234 [--apply]        # default is dry-run (prints only)
  whence --apply                    # find the PR for the current branch
  whence --pr 1234 --hide url,session --apply

Config (all optional, ~/.config/whence/config.json):
  {
    "hide":   ["url"],                 # fields to omit (labels + footer rows)
    "colors": {"agent":"1f6feb", "host":"1a7f37", "tab":"8250df"}
  }
Quick per-run override:  WHENCE_HIDE=url,session   or  --hide url,session
"""
from __future__ import annotations
import argparse, json, os, re, socket, subprocess, sys, datetime, pathlib

GH = "gh"                                          # resolved in main: WHENCE_GH env > config "gh" > "gh"
CFG_DIR = pathlib.Path.home() / ".config/whence"

# Fields, in footer order. `agent`/`host`/`tab` are also the queue labels.
# `workspace` = cmux workspace name; `tab` = the per-tab (surface) title you
# navigate by — the one you need most to find your way back.
FIELDS = ["agent", "host", "workspace", "tab", "session", "resume", "url", "jump", "relaunch", "stamped"]
LABEL_FIELDS = ["agent", "host", "workspace", "tab"]
DEFAULT_COLORS = {"agent": "1f6feb", "host": "1a7f37", "workspace": "bf8700", "tab": "8250df"}

# Friendly resume syntax for agents whose CLI we've verified. ANY other agent
# still works via the cmux-sourced `relaunch` command below — this is just for a
# prettier line. Add your agent here (PRs welcome).
KNOWN_RESUME = {"claude": "claude --resume {sid}", "codex": "codex resume {sid}"}
KNOWN_URL = {"claude": "https://claude.ai/code/{bridge}"}

MARK_RE = re.compile(r"<!-- whence( .*?)? -->.*?<!-- /whence -->\n?", re.S)
OLD_PREFIXES = ("agent:", "host:", "ws:")

# What counts as "a PR was just opened", matched against an agent hook's command.
PR_CMD_RE = re.compile(r"(?:gh|ghapp) pr create|shipyard pr|pulp pr")

# The whole config, every knob shown at its default. `whence --init` writes this.
# Flip any field false to drop it; set labels/footer false to drop a whole surface;
# set repos.mode to "allow"/"deny" with a list to scope which repos get stamped.
DEFAULT_CONFIG = {
    "fields": {f: True for f in FIELDS},
    "labels": True,
    "footer": True,
    "colors": dict(DEFAULT_COLORS),
    "repos": {"mode": "all", "list": []},
    "gh": "gh",
}


def sh(*a, **k):
    # Bounded + graceful: a missing binary (e.g. no cmux) or a slow network call
    # degrades to an empty result instead of crashing or hanging the caller.
    k.setdefault("timeout", 15)
    try:
        return subprocess.run(a, capture_output=True, text=True, **k)
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError) as e:
        return subprocess.CompletedProcess(a, 1, "", str(e))


def load_config(cli_hide: str) -> dict:
    # footer/labels default ON; either can be turned off globally or per-run.
    cfg = {"hide": set(), "colors": dict(DEFAULT_COLORS), "repos": {},
           "footer": True, "labels": True, "gh": ""}
    f = CFG_DIR / "config.json"
    if f.exists():
        try:
            d = json.loads(f.read_text())
            cfg["hide"] |= set(d.get("hide", []))
            cfg["colors"].update(d.get("colors", {}))
            cfg["repos"] = d.get("repos", {})   # {"mode":"all|allow|deny","list":["owner/repo"]}
            cfg["footer"] = bool(d.get("footer", True))   # post the PR-description footer?
            cfg["labels"] = bool(d.get("labels", True))   # post the queue labels?
            cfg["gh"] = str(d.get("gh", "") or "")        # gh binary, e.g. "ghapp" (App-token auth)
            # "fields": {"host": false, ...} — the easy per-field on/off switch.
            for name, on in (d.get("fields") or {}).items():
                if not on:
                    cfg["hide"].add(name)
        except Exception as e:
            print(f"whence: ignoring bad config.json: {e}", file=sys.stderr)
    for src in (os.environ.get("WHENCE_HIDE", ""), cli_hide or ""):
        cfg["hide"] |= {x.strip() for x in src.split(",") if x.strip()}
    unknown = cfg["hide"] - set(FIELDS)
    if unknown:
        print(f"whence: unknown hide field(s) ignored: {', '.join(sorted(unknown))} "
              f"(valid: {', '.join(FIELDS)})", file=sys.stderr)
    return cfg


def host_label() -> str:
    raw = socket.gethostname().split(".")[0]
    label = os.environ.get("WHENCE_HOST_LABEL", "").strip()
    if not label:
        f = CFG_DIR / "host-label"
        if f.exists():
            label = f.read_text().strip()
    return label or raw


def cmux_ws_name(ws_id: str) -> str:
    if not ws_id:
        return ""
    r = sh("cmux", "workspace", "list", "--id-format", "both")
    if r.returncode != 0:
        return ""
    for line in r.stdout.splitlines():
        if ws_id in line:
            after = re.sub(r"\s*\[[^\]]*\]\s*$", "", line.split(ws_id, 1)[1]).strip()
            return re.sub(r"^[\W_]+", "", after).strip()
    return ""


import unicodedata


def clean_title(t: str) -> str:
    """Strip cmux's leading status glyphs — spinner braille (⠙⠦⠐…), run/err/dirty
    emoji (🏃 ❌ ✳ …), and separators — leaving the human tab name."""
    i = 0
    while i < len(t):
        ch = t[i]
        if (ch.isspace() or unicodedata.category(ch).startswith("S")
                or 0x2800 <= ord(ch) <= 0x28FF or ord(ch) >= 0x1F000):
            i += 1
            continue
        break
    return t[i:].strip()


def cmux_workspace(ws_id: str) -> str:
    """The workspace name — your custom title if you set one, else cmux's
    (drifting) auto-title. See `has_custom_title` in `cmux rpc workspace.list`."""
    if not ws_id:
        return ""
    name = cmux_ws_name(ws_id)
    r = sh("cmux", "rpc", "workspace.list")
    if r.returncode == 0:
        try:
            for w in json.loads(r.stdout).get("workspaces", []):
                if w.get("id") == ws_id:
                    if w.get("has_custom_title") and w.get("custom_title"):
                        return clean_title(w["custom_title"])
                    break
        except Exception:
            pass
    return clean_title(name)


def cmux_tab_title(surface_id: str) -> tuple[str, str]:
    """The per-tab (surface) title — the name you navigate by — plus its cmux
    ref (e.g. `surface:13`) ONLY when another tab shares the same title (so two
    "pulp" tabs are tellable apart, but unique names stay clean). JSON-driven
    from `cmux rpc surface.list`; re-running whence re-reads the current title."""
    if not surface_id:
        return "", ""
    r = sh("cmux", "rpc", "surface.list")
    if r.returncode == 0:
        try:
            surfaces = json.loads(r.stdout).get("surfaces", [])
            counts, mine = {}, None
            for s in surfaces:
                t = clean_title(s.get("title") or "")
                counts[t] = counts.get(t, 0) + 1
                if s.get("id") == surface_id:
                    mine = (t, s.get("ref") or "")
            if mine:
                t, ref = mine
                return t, (ref if t and counts.get(t, 0) > 1 else "")
        except Exception:
            pass
    return "", ""


def collect() -> dict:
    agent = os.environ.get("CMUX_AGENT_LAUNCH_KIND") or (
        "claude" if os.environ.get("CLAUDECODE") else
        "codex" if os.environ.get("CODEX_SESSION_ID") or os.environ.get("CODEX_ROLLOUT_ID") else
        "unknown")
    surface = os.environ.get("CMUX_SURFACE_ID", "")
    p = {f: "" for f in FIELDS}
    p["agent"] = agent
    p["host"] = host_label()
    p["workspace"] = cmux_workspace(os.environ.get("CMUX_WORKSPACE_ID", ""))
    tab, ref = cmux_tab_title(surface)
    p["tab"] = f"{tab} ({ref})" if (tab and ref) else tab
    p["stamped"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%d %H:%M UTC")

    restore = ""
    if surface:
        r = sh("cmux", "surface", "resume", "get", "--surface", surface)
        if r.returncode == 0:
            restore = r.stdout.strip()
        p["jump"] = f"cmux surface focus {surface}"
        p["relaunch"] = f"cmux surface resume get --surface {surface}"  # exact cmd, any agent

    # Session id must be CONSISTENT with the detected agent — never pair claude's
    # session with codex's resume syntax (or vice versa) if both env vars leak in.
    if agent == "claude":
        sid = os.environ.get("CLAUDE_CODE_SESSION_ID", "")
    elif agent == "codex":
        sid = os.environ.get("CODEX_SESSION_ID") or os.environ.get("CODEX_ROLLOUT_ID") or ""
    else:
        sid = (os.environ.get("CLAUDE_CODE_SESSION_ID")
               or os.environ.get("CODEX_SESSION_ID") or os.environ.get("CODEX_ROLLOUT_ID") or "")
    if not sid and restore:
        m = re.search(r"[0-9a-fA-F]{8}-[0-9a-fA-F-]{27}", restore)
        sid = m.group(0) if m else ""
    p["session"] = sid

    if agent in KNOWN_RESUME and sid:
        p["resume"] = KNOWN_RESUME[agent].format(sid=sid)
    if agent in KNOWN_URL:
        bridge = os.environ.get("CLAUDE_CODE_BRIDGE_SESSION_ID", "")
        if bridge:
            p["url"] = KNOWN_URL[agent].format(bridge=bridge)
    return p


def visible(field: str, p: dict, hide: set) -> bool:
    return field not in hide and bool(p.get(field))


def labels_for(p: dict, cfg: dict) -> list[tuple[str, str]]:
    out = []
    for f in LABEL_FIELDS:
        if visible(f, p, cfg["hide"]):
            out.append((p[f][:50], cfg["colors"].get(f, "ededed")))
    return out


def footer(p: dict, cfg: dict, label_names: list[str]) -> str:
    hide = cfg["hide"]
    tag = json.dumps({"labels": label_names}, ensure_ascii=False)
    line1 = "  ·  ".join(
        f"**{lbl}** {fmt}" for f, lbl, fmt in [
            ("agent", "Agent", f"`{p['agent']}`"),
            ("host", "Machine", f"`{p['host']}`"),
        ] if visible(f, p, hide))
    # navigation line: workspace then tab — the tab title is the "find my way back" key
    nav = "  ·  ".join(
        f"**{lbl}** {fmt}" for f, lbl, fmt in [
            ("workspace", "Workspace", f"`{p['workspace']}`"),
            ("tab", "Tab", f"`{p['tab']}`"),
        ] if visible(f, p, hide))
    rows = [r for r in (line1, nav) if r]
    for f, lbl, val in [
        ("session", "Session", f"`{p['session']}`"),
        ("resume", "Resume", f"`{p['resume']}`"),
        ("url", "Restore URL", p["url"]),
        ("jump", "Jump to this tab", f"`{p['jump']}`"),
        ("relaunch", "Relaunch (any agent)", f"`{p['relaunch']}`"),
    ]:
        if visible(f, p, hide):
            rows.append(f"**{lbl}** {val}")
    if visible("stamped", p, hide):
        rows.append(f"<sub>stamped {p['stamped']}</sub>")
    body = "  \n".join(r for r in rows if r)
    return f"<!-- whence {tag} -->\n\n---\n### 🔎 Provenance\n{body}\n<!-- /whence -->"


def resolve_pr(args) -> str:
    if args.pr:
        return str(args.pr)
    br = args.branch or sh("git", "rev-parse", "--abbrev-ref", "HEAD").stdout.strip()
    return sh(GH, "pr", "view", br, "--json", "number", "-q", ".number").stdout.strip()


def repo_allowed(cfg: dict) -> bool:
    """Per-repo enable/disable. Two ways, either turns it off here:
    1. Drop a `.whence-off` file in the repo root  →  disabled in that repo.
    2. Global list in config: "repos": {"mode":"allow"|"deny","list":["owner/repo"]}."""
    top = sh("git", "rev-parse", "--show-toplevel").stdout.strip()
    if top and (pathlib.Path(top) / ".whence-off").exists():
        return False
    r = cfg.get("repos") or {}
    mode = r.get("mode", "all")
    if mode == "all":
        return True
    slug = sh(GH, "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner").stdout.strip()
    lst = set(r.get("list", []))
    if mode == "allow":
        return slug in lst
    if mode == "deny":
        return slug not in lst
    return True


# The one cross-agent trigger: wrap the command that opens the PR. Every agent
# shells out to one of these, so a PATH shim catches them all — no per-agent hook,
# no Shipyard requirement. Key = tool name, value = the sh test that means "a PR
# was just opened" (so the shim only stamps on PR-creating invocations). We cover
# every common way a PR gets opened: the GitHub CLIs (`gh`/`ghapp pr create`) and
# the orchestrators (`shipyard pr`, `pulp pr`). Over-firing is harmless — whence
# no-ops when the branch has no PR — so it's fine to err toward catching more.
PR_TOOLS = {
    "shipyard": '[ "$1" = pr ]',
    "pulp":     '[ "$1" = pr ]',
    "gh":       '[ "$1" = pr ] && [ "$2" = create ]',
    "ghapp":    '[ "$1" = pr ] && [ "$2" = create ]',
}
HOOK_MARK_RE = re.compile(r"\n*# >>> whence hook >>>.*?# <<< whence hook <<<\n", re.S)
HOOK_FILE = CFG_DIR / "hook.sh"


def _hook_source_block() -> str:
    return ("# >>> whence hook >>>  (managed by `whence --install-hook`; safe to delete)\n"
            f'[ -f "{HOOK_FILE}" ] && . "{HOOK_FILE}"\n'
            "# <<< whence hook <<<\n")


def _hook_file_text() -> tuple[str, list]:
    """Build the sourced functions file. A shell FUNCTION beats PATH lookup in
    EVERY shell mode (interactive or not), so — unlike a PATH-dir shim — it can't
    be shadowed by a later .zshrc reordering PATH. Each function runs the REAL
    tool via `command` (which skips functions → no recursion, and no double-stamp
    when one tool internally spawns another), then stamps best-effort."""
    from shutil import which
    tools = [(t, trig) for t, trig in PR_TOOLS.items() if which(t)]
    lines = [
        "# whence hook — sourced by your shell init. Thin wrappers around the",
        "# PR-opening commands that stamp the branch's PR right after it opens.",
        "# A function beats PATH, so this fires regardless of PATH order; `command`",
        "# runs the real tool (no recursion); the stamp never changes the exit code.",
        "# NB: `command whence` — plain `whence` is a zsh BUILTIN (like `which`), so",
        "# `command` is required to reach this script rather than the builtin.",
        "__whence_stamp() { command whence --auto >/dev/null 2>&1 || true; }",
    ]
    for tool, trig in tools:
        lines.append(
            f'{tool}() {{ command {tool} "$@"; __whence_rc=$?; '
            f"if {trig}; then __whence_stamp; fi; return $__whence_rc; }}")
    return "\n".join(lines) + "\n", [t for t, _ in tools]


def install_hook(print_only: bool) -> int:
    """Install (or print) the shell-function hook that stamps every future PR at
    open time, for any agent, without depending on Shipyard."""
    text, tools = _hook_file_text()
    block = _hook_source_block()
    if print_only:
        print(f"# hook file: {HOOK_FILE}")
        print(f"# wraps: {', '.join(tools) or '(no PR tool found on PATH)'}")
        print("\n# ---- hook.sh ----\n" + text)
        print("# add to ~/.zshenv (and ~/.bashrc if you use bash):\n" + block)
        return 0
    if not tools:
        print("whence: found no PR tool (shipyard/pulp/gh/ghapp) on PATH — nothing to wrap.\n"
              "  Install one, or wire an agent hook instead (see the README).", file=sys.stderr)
        return 1
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    HOOK_FILE.write_text(text)
    targets = [pathlib.Path(os.path.expanduser("~/.zshenv"))]  # always: universal zsh init
    bashrc = pathlib.Path(os.path.expanduser("~/.bashrc"))
    if bashrc.exists():
        targets.append(bashrc)
    for rcp in targets:
        cur = rcp.read_text() if rcp.exists() else ""
        cur = HOOK_MARK_RE.sub("\n", cur).rstrip()
        rcp.write_text((cur + "\n\n" + block) if cur else block)
    print(f"whence: wrote hook {HOOK_FILE}")
    print(f"  wraps: {', '.join(tools)}")
    print("  sourced from: " + ", ".join(str(t) for t in targets))
    print("Open a new shell/tab (or `source ~/.zshenv`) to activate. "
          "Every PR opened after that self-stamps.")
    return 0


def uninstall_hook() -> int:
    """Remove the hook file and the sourcing block — full reversal of --install-hook."""
    existed = HOOK_FILE.exists()
    if existed:
        HOOK_FILE.unlink()
    for rc in ("~/.zshenv", "~/.bashrc"):
        rcp = pathlib.Path(os.path.expanduser(rc))
        if not rcp.exists():
            continue
        cur = rcp.read_text()
        new = HOOK_MARK_RE.sub("\n", cur)
        new = new.rstrip() + "\n" if new.strip() else ""
        if new != cur:
            rcp.write_text(new)
    print(f"whence: removed hook {'file' if existed else '(none)'} and the sourcing block.")
    print("Open a new shell/tab for it to take full effect.")
    return 0


PR_HOOK = CFG_DIR / "pr-hook.sh"


def _write_pr_hook() -> pathlib.Path:
    """Write the tiny stdin shim an agent's PostToolUse hook runs. It just pipes
    the tool JSON into `whence --hook` (all parsing/matching happens in-process,
    so there's no fragile shell quoting). whence is called by absolute path
    because plain `whence` is a zsh builtin."""
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    whence_bin = os.path.realpath(sys.argv[0])
    PR_HOOK.write_text(
        "#!/bin/sh\n"
        "# whence agent PR hook — an agent PostToolUse hook pipes the tool-call JSON\n"
        "# to this on stdin; whence decides whether it opened a PR and stamps it.\n"
        "# Always exits 0 so a stamping hiccup never breaks the agent.\n"
        f'"{whence_bin}" --hook || true\n'
        "exit 0\n")
    PR_HOOK.chmod(0o755)
    return PR_HOOK


def _wire_posttooluse(path: pathlib.Path, matcher: str, extra: dict) -> None:
    """Idempotently add a PostToolUse entry pointing at pr-hook.sh to a Claude/
    Codex-style hooks JSON (they share the schema)."""
    d = {}
    if path.exists():
        try: d = json.loads(path.read_text())
        except Exception: d = {}
    ptu = d.setdefault("hooks", {}).setdefault("PostToolUse", [])
    cmd = str(PR_HOOK)
    def has(e): return any(x.get("command", "").endswith("pr-hook.sh") for x in e.get("hooks", []))
    mine = [e for e in ptu if e.get("matcher") == matcher or has(e)]
    entry = {"type": "command", "command": cmd, **extra}
    if any(has(e) for e in ptu):
        for e in ptu:
            if has(e):
                e["hooks"] = [x for x in e["hooks"] if not x.get("command", "").endswith("pr-hook.sh")] + [entry]
    elif mine:
        mine[0].setdefault("hooks", []).append(entry)
    else:
        ptu.append({"matcher": matcher, "hooks": [entry]})
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(d, indent=2) + "\n")


def install_agent_hook(scope: str) -> int:
    """Wire the reliable in-process agent hooks: Claude globally, Codex per-repo
    (Codex only reads a repo's own .codex/hooks.json, and gates it behind trust)."""
    _write_pr_hook()
    did = []
    if scope in ("all", "claude"):
        _wire_posttooluse(pathlib.Path(os.path.expanduser("~/.claude/settings.json")),
                          "Bash", {})
        did.append("claude (~/.claude/settings.json, global)")
    if scope in ("all", "codex"):
        top = sh("git", "rev-parse", "--show-toplevel").stdout.strip() or os.getcwd()
        _wire_posttooluse(pathlib.Path(top) / ".codex/hooks.json",
                          "Bash|Shell|shell|local_shell|exec", {"timeout": 20000})
        did.append(f"codex ({top}/.codex/hooks.json, this repo)")
    print(f"whence: wrote {PR_HOOK}")
    for d in did:
        print(f"  wired {d}")
    if scope in ("all", "codex"):
        print("\nCodex note: Codex reads each repo's own .codex/hooks.json and gates it\n"
              "behind trust — it will ask you to trust the hook on its next run here.\n"
              "Run `whence --install-agent-hook codex` inside each repo you want covered.")
    return 0


def _best_gh() -> str:
    """Pick the GitHub CLI to use for whence's own calls: gh if present, else
    ghapp (App-token). Lets machines that only have ghapp work with zero config."""
    from shutil import which
    return "gh" if which("gh") else ("ghapp" if which("ghapp") else "gh")


def setup(host: str | None) -> int:
    """One-shot guided setup: name the machine, write the config (auto-picking the
    GitHub CLI), and install the every-future-PR hook. Reports what it will catch."""
    from shutil import which
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    hf = CFG_DIR / "host-label"
    if host and host.strip():
        hf.write_text(host.strip() + "\n"); hs = host.strip()
    elif hf.exists() and hf.read_text().strip():
        hs = hf.read_text().strip()
    else:
        hs = socket.gethostname().split(".")[0]
        hf.write_text(hs + "\n")
    cf = CFG_DIR / "config.json"
    cfg = dict(DEFAULT_CONFIG)
    if cf.exists():
        try: cfg = json.loads(cf.read_text())
        except Exception: pass
    # Auto-pick the GitHub CLI unless the user already set a non-default one.
    if not cfg.get("gh") or cfg.get("gh") == "gh":
        cfg["gh"] = _best_gh()
    cf.write_text(json.dumps(cfg, indent=2) + "\n")

    print(f"whence setup")
    print(f"  machine label : {hs}   ({hf})")
    print(f"  github CLI    : {cfg['gh']}   (for whence's own calls)")
    print(f"  config        : {cf}")
    have = [t for t in PR_TOOLS if which(t)]
    print(f"  will catch PRs opened via: {', '.join(have) or '(none found — install gh/ghapp/shipyard/pulp)'}")
    print()
    rc = install_hook(print_only=False)
    print("\nSetup complete. New PRs from this machine self-stamp once you open a fresh shell/tab.")
    return rc


def resync() -> int:
    """Refresh THIS tab's open PRs with the current name — on demand, no tracking.
    Each PR whence stamped carries this tab's stable surface id in its footer, so
    we just search open PRs for it and re-stamp (idempotent). Run it after you
    rename a tab; nothing monitors in the background."""
    surface = os.environ.get("CMUX_SURFACE_ID", "")
    if not surface:
        print("whence: no CMUX_SURFACE_ID in this shell — can't identify this tab's PRs",
              file=sys.stderr)
        return 2
    r = sh(GH, "pr", "list", "--state", "open", "--search", surface,
           "--json", "number", "-q", ".[].number")
    nums = [x for x in r.stdout.split() if x.strip()]
    if not nums:
        print("whence: no open PRs stamped from this tab — nothing to resync")
        return 0
    print(f"whence: refreshing {len(nums)} open PR(s) from this tab: "
          + ", ".join("#" + n for n in nums))
    self = os.path.realpath(sys.argv[0])
    for n in nums:
        sh(sys.executable, self, "--pr", n, "--apply")
        print(f"  #{n} refreshed")
    return 0


def write_default_config(force: bool) -> None:
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    f = CFG_DIR / "config.json"
    if f.exists() and not force:
        print(f"whence: config already exists at {f}\n"
              f"  edit it, or re-run `whence --init --force` to reset it to defaults")
        return
    f.write_text(json.dumps(DEFAULT_CONFIG, indent=2) + "\n")
    print(f"whence: wrote {f}\n"
          f"  Flip any \"fields\" value to false to drop it (labels + footer).\n"
          f"  Set \"labels\": false or \"footer\": false to drop a whole surface.\n"
          f"  Scope repos with \"repos\": {{\"mode\":\"allow\"|\"deny\",\"list\":[\"owner/repo\"]}}.")


def prior_labels(body: str) -> list:
    m = re.search(r"<!-- whence (\{.*?\}) -->", body)
    if m:
        try: return json.loads(m.group(1)).get("labels", [])
        except Exception: pass
    return []


def main() -> int:
    global GH
    ap = argparse.ArgumentParser(description="Stamp a PR with agent/session/machine/tab provenance.")
    ap.add_argument("--pr"); ap.add_argument("--branch")
    ap.add_argument("--hide", help="comma list of fields to omit this run: " + ",".join(FIELDS))
    ap.add_argument("--no-footer", action="store_true", help="don't post the PR-description footer")
    ap.add_argument("--no-labels", action="store_true", help="don't post the queue labels")
    ap.add_argument("--apply", action="store_true", help="mutate the PR (default: dry-run)")
    ap.add_argument("--auto", action="store_true",
                    help="hook mode: apply, quiet, skip silently if the repo is off or has no PR")
    ap.add_argument("--init", action="store_true", help="write an editable config with every knob")
    ap.add_argument("--force", action="store_true", help="with --init, overwrite an existing config")
    ap.add_argument("--show", action="store_true", help="print the effective config and where it lives")
    ap.add_argument("--setup", action="store_true",
                    help="guided one-shot: name the machine, write config, install the hook")
    ap.add_argument("--host", help="machine label to use with --setup (default: hostname)")
    ap.add_argument("--install-hook", action="store_true",
                    help="install the PATH shim so every future PR self-stamps (any agent)")
    ap.add_argument("--uninstall-hook", action="store_true",
                    help="remove the shim and PATH block (full reversal of --install-hook)")
    ap.add_argument("--print-hook", action="store_true",
                    help="print the shim + shell snippet without writing anything")
    ap.add_argument("--resync", action="store_true",
                    help="re-stamp this tab's open PRs with the current name (on demand)")
    ap.add_argument("--install-agent-hook", nargs="?", const="all", choices=["all", "claude", "codex"],
                    metavar="all|claude|codex",
                    help="wire the reliable in-process agent hook (Claude global, Codex per-repo)")
    ap.add_argument("--hook", action="store_true",
                    help="internal: read an agent's tool JSON from stdin and stamp if it opened a PR")
    args = ap.parse_args()

    if args.install_agent_hook:
        return install_agent_hook(args.install_agent_hook)
    if args.resync:
        cfg = load_config(args.hide)
        GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"
        return resync()
    if args.setup:
        return setup(args.host)
    if args.print_hook:
        return install_hook(print_only=True)
    if args.install_hook:
        return install_hook(print_only=False)
    if args.uninstall_hook:
        return uninstall_hook()
    if args.init:
        write_default_config(args.force); return 0

    cfg = load_config(args.hide)
    GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"   # env > config "gh" > "gh"

    if args.hook:
        # Agent PostToolUse: read the tool JSON, stamp only if it opened a PR.
        if sys.stdin.isatty():   # run by hand with no piped input — don't block
            return 0
        try: raw = sys.stdin.read()
        except Exception: raw = ""
        cmd = ""
        try:
            d = json.loads(raw); ti = d.get("tool_input") or d.get("toolInput") or {}
            cmd = ti.get("command") or ti.get("cmd") or ""
        except Exception:
            cmd = ""
        if not PR_CMD_RE.search(cmd or raw):
            return 0
        args.auto = True   # a PR was opened → fall through and stamp it quietly

    post_labels = cfg["labels"] and not args.no_labels
    post_footer = cfg["footer"] and not args.no_footer

    if args.show:
        f = CFG_DIR / "config.json"
        shown = [x for x in FIELDS if x not in cfg["hide"]]
        rp = cfg.get("repos") or {}
        scope = rp.get("mode", "all")
        print(f"config file:  {f}  ({'exists' if f.exists() else 'not created — run: whence --init'})")
        print(f"per-repo off: drop a `.whence-off` file in a repo's root to disable it there")
        print(f"\nlabels posted: {post_labels}    footer posted: {post_footer}")
        print(f"fields shown:  {', '.join(shown) or '(none)'}")
        print(f"fields hidden: {', '.join(sorted(cfg['hide'])) or '(none)'}")
        print(f"repo scope:    {scope}" + (f"  {rp.get('list', [])}" if scope != "all" else "  (every repo)"))
        return 0

    if not repo_allowed(cfg):
        if not args.auto:
            print("whence: this repo is disabled (.whence-off file or repos config) — skipping")
        return 0

    p = collect()
    labels = labels_for(p, cfg) if post_labels else []
    names = [n for n, _ in labels]
    ft = footer(p, cfg, names) if post_footer else ""

    if not args.auto:
        print("── Provenance ──")
        for k in FIELDS:
            print(f"  {k:9} {p[k]}" + ("" if visible(k, p, cfg['hide']) else "  (hidden)"))
        print("\n── Labels ──" if post_labels else "\n── Labels (disabled) ──")
        for n, c in labels:
            print(f"  #{c}  {n}")
        print("\n── Footer ──\n" + ft if post_footer else "\n── Footer (disabled) ──")
    if not args.apply and not args.auto:
        print("\n[dry-run] pass --apply to stamp the PR")
        return 0

    pr = resolve_pr(args)
    if not pr:
        if args.auto:
            return 0
        print("whence: could not resolve a PR", file=sys.stderr); return 2

    body = sh(GH, "pr", "view", pr, "--json", "body", "-q", ".body").stdout
    # Labels: apply the current set, or (if disabled) remove any we left before.
    keep = set(names)
    existing = sh(GH, "pr", "view", pr, "--json", "labels", "-q", ".labels[].name").stdout.split("\n")
    stale = (set(prior_labels(body)) | {l for l in existing if l and l.startswith(OLD_PREFIXES)}) - keep
    for s in sorted(x for x in stale if x):
        sh(GH, "pr", "edit", pr, "--remove-label", s)
    for n, c in labels:
        sh(GH, "label", "create", n, "--color", c, "--force")
    if names:
        sh(GH, "pr", "edit", pr, *sum([["--add-label", n] for n in names], []))
    # Footer: post it, or (if disabled) strip any prior footer we left behind.
    stripped = MARK_RE.sub("", body).rstrip()
    newbody = (stripped + "\n\n" + ft) if post_footer else (stripped + "\n")
    if newbody != body:
        tmp = pathlib.Path("/tmp") / f"whence-body-{pr}.md"
        tmp.write_text(newbody)
        sh(GH, "pr", "edit", pr, "--body-file", str(tmp))
    print(f"\n✓ PR #{pr}: " + (", ".join(names) if names else "labels off")
          + (" + footer" if post_footer else " · footer off"))
    return 0


if __name__ == "__main__":
    sys.exit(main())
