    ap.add_argument("--print-hook", action="store_true",
                    help="print the shim + shell snippet without writing anything")
    ap.add_argument("--resync", action="store_true",
                    help="re-stamp this tab's open PRs with the current name (on demand)")
    ap.add_argument("--sweep", action="store_true",
                    help="stamp any open PR in the branch-ledger that isn't stamped yet "
                         "(catches worktree/daemon/push-only/timed-out PRs)")
    ap.add_argument("--deploy", action="store_true",
                    help="push local whence changes, then SSH ~/.config/whence/hosts to pull+reinstall")
    ap.add_argument("--self-update", dest="selfupdate", action="store_true",
                    help="fast-forward this whence clone to the repo now and reinstall the hook")
    ap.add_argument("--install-agent-hook", nargs="?", const="all", choices=["all", "claude", "codex"],
                    metavar="all|claude|codex",
                    help="wire the reliable in-process agent hook (Claude global, Codex per-repo)")
    ap.add_argument("--hook", action="store_true",
                    help="internal: read an agent's tool JSON from stdin and stamp if it opened a PR")
    ap.add_argument("--pre-exec", metavar="CWD", help=argparse.SUPPRESS)
    ap.add_argument("--retry-key", help=argparse.SUPPRESS)
    args = ap.parse_args()

    if args.install_agent_hook:
        return install_agent_hook(args.install_agent_hook)
    if args.deploy:
        return deploy()
    if args.selfupdate:
        print("whence: updated to latest" if self_update(force=True) else "whence: already current")
        return 0
    if args.resync:
        cfg = load_config(args.hide)
        GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"
        return resync()
    if args.retry_key:
        cfg = load_config(args.hide)
        GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"
        cfg["labels"] = cfg["labels"] and not args.no_labels
        cfg["footer"] = cfg["footer"] and not args.no_footer
        return retry_pending_pr(args.retry_key, cfg)
    if args.pre_exec:
        cfg = load_config(args.hide)
        GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"
        post_labels = cfg["labels"] and not args.no_labels
        post_footer = cfg["footer"] and not args.no_footer
        preexec_capture(args.pre_exec, cfg, post_labels, post_footer)
        return 0
    if args.sweep:
        cfg = load_config(args.hide)
        GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"
        # Inbound config catch-up on the same 10-min tick every host already runs.
        # A machine that was offline when you edited converges here after it wakes.
        try:
            if pull_config():
                print("whence: pulled updated fleet config")
        except Exception:
            pass
        print(f"whence: swept {sweep(cfg)} PR(s)")
        return 0
    if args.setup:
        return setup(args.host)
    if args.print_hook:
        return install_hook(print_only=True)
    if args.install_hook:
        return install_hook(print_only=False)
    if args.uninstall_hook:
        return uninstall_hook()
    if args.init:
        write_default_config(args.force); return 0
    if args.log is not None:
        return show_log(args.log)
    if args.audit:
        return set_audit(args.audit == "on")
    if args.gc_labels:
        cfg = load_config(args.hide)
        GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"
        return gc_labels(cfg, args.gc_labels)
    if args.reorder_labels:
        cfg = load_config(args.hide)
        GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"
        return reorder_labels(cfg, args.reorder_labels)
    if args.install_sweep:
        return install_sweep()
    if args.uninstall_sweep:
        return install_sweep(uninstall=True)
    if args.init_config_repo:
        return init_config_repo(args.init_config_repo)
    if args.pull_config:
        print("config updated" if pull_config() else "config already current"); return 0
    if args.push_config:
        return push_config()
    if args.install_config_watch:
        return install_config_watch()
    if args.uninstall_config_watch:
        return install_config_watch(uninstall=True)

    cfg = load_config(args.hide)
    GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"   # env > config "gh" > "gh"

    hook_agent = hook_sid = hook_cmd = hook_cwd = ""
    hook_slug = hook_br = hook_pr = hook_source_ref = ""
    ledger_key = ""
    hook_is_pr = hook_is_push = False
    if args.hook:
        # Agent PostToolUse: read the tool JSON. A PR-create command stamps now;
        # a push (which may open a PR later, via a daemon) records the branch's
        # provenance for the sweep. The payload carries the true identity
        # (session_id + transcript_path), more reliable than leak-prone env vars.
        if sys.stdin.isatty():   # run by hand with no piped input — don't block
            return 0
        try: raw = sys.stdin.read()
        except Exception: raw = ""
        try:
            d = json.loads(raw); ti = d.get("tool_input") or d.get("toolInput") or {}
            hook_cmd = ti.get("command") or ti.get("cmd") or ""
            hook_sid = d.get("session_id") or ""
            tp = d.get("transcript_path") or ""
            hook_agent = ("codex" if "/.codex" in tp else
                          "claude" if "/.claude" in tp else "")
            hook_slug, hook_br, hook_pr = parse_outcome(d)
            hook_source_ref = pushed_source_ref(d)
            hook_cwd = d.get("cwd") or ""
        except Exception:
            hook_cmd = ""
        # The output outranks the command name: anything that printed a PR URL
        # opened a PR, no matter which wrapper it was spelled with.
        cmd_is_pr, cmd_is_push, _action_cwd = _command_action(hook_cmd)
        hook_is_pr = bool(hook_pr) or cmd_is_pr
        hook_is_push = cmd_is_push or bool(hook_slug and hook_br)
        if not (hook_is_pr or hook_is_push):
            return 0
        args.auto = True   # quiet mode for both; a push returns before stamping

    post_labels = cfg["labels"] and not args.no_labels
    post_footer = cfg["footer"] and not args.no_footer

    if args.show:
        f = CFG_DIR / "config.json"
        shown = [x for x in FIELDS if x not in cfg["hide"]]
        rp = cfg.get("repos") or {}
        scope = rp.get("mode", "all")
        print(f"config file:  {f}  ({'exists' if f.exists() else 'not created — run: whence --init'})")
        print(f"per-repo off: drop a `.whence-off` file in a repo's root to disable it there")
        print(f"\nlabels posted: {post_labels}    footer posted: {post_footer}")
        print(f"fields shown:  {', '.join(shown) or '(none)'}")
        print(f"fields hidden: {', '.join(sorted(cfg['hide'])) or '(none)'}")
        print(f"repo scope:    {scope}" + (f"  {rp.get('list', [])}" if scope != "all" else "  (every repo)"))
        return 0

    if not repo_allowed(cfg, hook_slug):
        if not args.auto:
            print("whence: this repo is disabled (.whence-off file or repos config) — skipping")
        return 0

    p = collect(cfg)
    if args.hook:
        p["path"] = sanitize_path(_cmd_cwd(hook_cmd) or hook_cwd or os.getcwd(), cfg)
        # Prefer the hook payload's identity over env (which can leak across
        # sessions): the session id is authoritative; use the transcript's agent
        # only when env couldn't name one. Keep resume consistent with both.
        if hook_agent and p["agent"] in ("", "unknown"):
            p["agent"] = hook_agent
        if hook_sid:
            p["session"] = hook_sid
        if p["agent"] in KNOWN_RESUME and p["session"]:
            p["resume"] = KNOWN_RESUME[p["agent"]].format(sid=p["session"])
        elif p["agent"] not in KNOWN_RESUME:
            p["resume"] = ""
        # Capture this branch's provenance while the env is live, then run the
        # cheap throttled maintenance: converge to the repo + backfill any PR the
        # live stamp couldn't reach (worktree / daemon / push-only / timed-out).
        if hook_is_pr or hook_is_push:
            ledger_key = ledger_record(hook_cmd, p, hook_slug, hook_br,
                                       hook_source_ref, hook_cwd)
        try: self_update()                       # throttled once/day internally
        except Exception: pass
        try:
            if _throttled("sweep", 120): sweep(cfg)
        except Exception: pass
        maybe_retry_deferred_pr(hook_is_pr, hook_pr, ledger_key,
                                cfg, post_labels, post_footer)
        if not hook_is_pr:                        # a push only records + sweeps
            return 0
    labels = labels_for(p, cfg) if post_labels else []
    names = [n for n, _ in labels]
    ft = footer(p, cfg, names) if post_footer else ""

    if not args.auto:
        print("── Provenance ──")
        for k in FIELDS:
            note = "" if visible(k, p, cfg['hide']) else "  (hidden)"
            if k in p.get("_redacted", []):
                note = "  (REDACTED — matched denylist)"
            print(f"  {k:9} {p[k]}{note}")
        print("\n── Labels ──" if post_labels else "\n── Labels (disabled) ──")
        for n, c in labels:
            print(f"  #{c}  {n}")
        print("\n── Footer ──\n" + ft if post_footer else "\n── Footer (disabled) ──")
    if not args.apply and not args.auto:
        print("\n[dry-run] pass --apply to stamp the PR")
        return 0

    pr, repo = (hook_pr, hook_slug) if hook_pr else (resolve_pr(args), "")
    if not pr:
        # The command opened no PR we can name (e.g. a plain push, or a PR the
        # daemon opens later). It's in the ledger — the sweep will catch it.
        if args.auto:
            return 0
        print("whence: could not resolve a PR", file=sys.stderr); return 2

    names = apply_stamp(pr, p, cfg, post_labels, post_footer, repo=repo,
                        source=("hook" if args.hook else "manual"))
    print(f"\n✓ PR #{pr}: " + (", ".join(names) if names else "labels off")
          + (" + footer" if post_footer else " · footer off"))
    return 0


if __name__ == "__main__":
    sys.exit(main())
