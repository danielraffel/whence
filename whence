#!/usr/bin/env python3
"""whence — stamp a PR with the provenance of the agent that made it.

Attaches, at PR-open time: prefix-free color-coded labels (agent, machine, cmux
tab) and a visible footer (session id, resume/relaunch commands, restore URL,
jump-to-tab). Works for ANY agent cmux launches — the resume/relaunch handles
come from cmux's own per-tab session-restore, so no agent-specific config is
needed. Every field is toggleable via config.

Usage:
  whence --pr 1234 [--apply]        # default is dry-run (prints only)
  whence --apply                    # find the PR for the current branch
  whence --pr 1234 --hide url,session --apply

Config (all optional, ~/.config/whence/config.json):
  {
    "hide":   ["url"],                 # fields to omit (labels + footer rows)
    "colors": {"agent":"1f6feb", "host":"1a7f37", "tab":"8250df"}
  }
Quick per-run override:  WHENCE_HIDE=url,session   or  --hide url,session
"""
from __future__ import annotations
import argparse, json, os, re, socket, subprocess, sys, datetime, pathlib, tempfile

GH = "gh"                                          # resolved in main: WHENCE_GH env > config "gh" > "gh"
CFG_DIR = pathlib.Path.home() / ".config/whence"

# Fields, in footer order. `agent`/`host`/`tab` are also the queue labels.
# `workspace` = cmux workspace name; `tab` = the per-tab (surface) title you
# navigate by — the one you need most to find your way back.
FIELDS = ["agent", "host", "workspace", "tab", "session", "resume", "url", "jump", "relaunch", "stamped"]
LABEL_FIELDS = ["agent", "host", "workspace", "tab"]
DEFAULT_COLORS = {"agent": "1f6feb", "host": "1a7f37", "workspace": "bf8700", "tab": "8250df"}

# Friendly resume syntax for agents whose CLI we've verified. ANY other agent
# still works via the cmux-sourced `relaunch` command below — this is just for a
# prettier line. Add your agent here (PRs welcome).
KNOWN_RESUME = {"claude": "claude --resume {sid}", "codex": "codex resume {sid}"}
KNOWN_URL = {"claude": "https://claude.ai/code/{bridge}"}

MARK_RE = re.compile(r"<!-- whence( .*?)? -->.*?<!-- /whence -->\n?", re.S)
OLD_PREFIXES = ("agent:", "host:", "ws:")

# What counts as "a PR was just opened", matched against an agent hook's command.
PR_CMD_RE = re.compile(r"(?:gh|ghapp) pr create|shipyard pr|pulp pr")
# A push may create a PR later (a daemon opens it, or `shipyard pr` pushes then
# opens asynchronously). We can't stamp a PR that doesn't exist yet, but we CAN
# record the branch's provenance now so the sweep stamps the PR when it appears.
PUSH_RE = re.compile(r"\bgit\s+push\b|\bshipyard\s+pr\b|\bpulp\s+pr\b")

# The command's OUTPUT names its own outcome — the PR URL that `gh`/`shipyard`
# print, or the `To github.com:owner/repo.git` + refspec that `git push` prints.
# That is the ONLY cwd-independent source of truth we get. Inferring the repo and
# branch from the hook's cwd instead is what silently drops PRs: an agent hook
# runs in the SESSION's project root, which is NOT the worktree the command ran
# in, so anything shipped from a worktree resolved the wrong branch and no-op'd.
# Reading the output works no matter what shells out to what — gh, shipyard, pulp,
# a bare `git push`, a script — because they all have to print where the code went.
PR_URL_RE = re.compile(r"https://github\.com/([\w.-]+/[\w.-]+?)(?:\.git)?/pull/(\d+)\b")
NEW_PR_RE = re.compile(r"https://github\.com/([\w.-]+/[\w.-]+?)(?:\.git)?/pull/new/(\S+)")
PUSH_TO_RE = re.compile(r"^To (?:(?:\w+://)?(?:[\w.-]+@)?github\.com[:/])"
                        r"([\w.-]+/[\w.-]+?)(?:\.git)?/?$", re.M)
# `   abc1234..def5678  fix/x -> fix/x`, ` * [new branch]  fix/x -> fix/x`,
# ` + 999f...888e  fix/x -> fix/x (forced update)` — the trailing note is optional.
REFSPEC_RE = re.compile(r"^[\s+*-]*(?:\[new branch\]|\[new tag\]|[0-9a-f]{4,}\.{2,3}[0-9a-f]{4,})"
                        r"\s+\S+\s+->\s+(\S+?)(?:\s+\(.*\))?\s*$", re.M)


def parse_outcome(payload: dict) -> tuple[str, str, str]:
    """(repo_slug, branch, pr_number) as reported by the command itself.

    Any field may be "" — a `git push` names a repo+branch but no PR (the PR may
    not exist yet); a `gh pr create` names a repo+PR directly. Reads stdout AND
    stderr: git writes its refspec summary to stderr."""
    tr = payload.get("tool_response") or payload.get("toolResponse") or ""
    if isinstance(tr, dict):
        tr = "\n".join(str(tr.get(k) or "") for k in ("stdout", "stderr", "output", "content"))
    elif not isinstance(tr, str):
        tr = str(tr)
    slug = branch = pr = ""
    m = PR_URL_RE.search(tr)
    if m:
        slug, pr = m.group(1), m.group(2)
    if not slug:
        m = NEW_PR_RE.search(tr) or PUSH_TO_RE.search(tr)
        if m:
            slug = m.group(1)
            if m.re is NEW_PR_RE:
                branch = m.group(2)
    if slug and not branch:
        # Gated on `slug`: a refspec with no GitHub repo above it came from some
        # OTHER remote, and pairing that branch with a cwd-derived GitHub slug
        # would file the entry under a repo the push never touched.
        m = REFSPEC_RE.search(tr)
        if m and m.group(1) != "HEAD":
            branch = m.group(1)
            if branch.startswith("refs/heads/"):
                branch = branch[len("refs/heads/"):]
    return slug, branch, pr


# The whole config, every knob shown at its default. `whence --init` writes this.
# Flip any field false to drop it; set labels/footer false to drop a whole surface;
# set repos.mode to "allow"/"deny" with a list to scope which repos get stamped.
DEFAULT_CONFIG = {
    "fields": {f: True for f in FIELDS},
    "labels": True,
    "footer": True,
    "colors": dict(DEFAULT_COLORS),
    "repos": {"mode": "all", "list": []},
    "gh": "gh",
    "label_maxlen": 24,
}


def sh(*a, **k):
    # Bounded + graceful: a missing binary (e.g. no cmux) or a slow network call
    # degrades to an empty result instead of crashing or hanging the caller.
    k.setdefault("timeout", 15)
    try:
        return subprocess.run(a, capture_output=True, text=True, **k)
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError) as e:
        return subprocess.CompletedProcess(a, 1, "", str(e))


def load_config(cli_hide: str) -> dict:
    # footer/labels default ON; either can be turned off globally or per-run.
    cfg = {"hide": set(), "colors": dict(DEFAULT_COLORS), "repos": {},
           "footer": True, "labels": True, "gh": "", "label_maxlen": 24}
    f = CFG_DIR / "config.json"
    if f.exists():
        try:
            d = json.loads(f.read_text())
        except Exception as e:
            print(f"whence: ignoring bad config.json: {e}", file=sys.stderr)
            d = {}
        if not isinstance(d, dict):
            d = {}
        # Each field is read independently — a single bad value keeps that field's
        # default instead of discarding the whole config.
        def field(key, apply):
            if key in d:
                try: apply(d[key])
                except Exception: print(f"whence: ignoring bad config field '{key}'", file=sys.stderr)
        field("hide", lambda v: cfg["hide"].update(set(v)))
        field("colors", lambda v: cfg["colors"].update(v))
        field("repos", lambda v: cfg.__setitem__("repos", v if isinstance(v, dict) else cfg["repos"]))
        field("footer", lambda v: cfg.__setitem__("footer", bool(v)))
        field("labels", lambda v: cfg.__setitem__("labels", bool(v)))
        field("gh", lambda v: cfg.__setitem__("gh", str(v or "")))
        field("label_maxlen", lambda v: cfg.__setitem__("label_maxlen", int(v)))
        # "fields": {"host": false, ...} — the easy per-field on/off switch.
        field("fields", lambda v: [cfg["hide"].add(n) for n, on in v.items() if not on])
    for src in (os.environ.get("WHENCE_HIDE", ""), cli_hide or ""):
        cfg["hide"] |= {x.strip() for x in src.split(",") if x.strip()}
    unknown = cfg["hide"] - set(FIELDS)
    if unknown:
        print(f"whence: unknown hide field(s) ignored: {', '.join(sorted(unknown))} "
              f"(valid: {', '.join(FIELDS)})", file=sys.stderr)
    return cfg


def host_label() -> str:
    raw = socket.gethostname().split(".")[0]
    label = os.environ.get("WHENCE_HOST_LABEL", "").strip()
    if not label:
        f = CFG_DIR / "host-label"
        if f.exists():
            label = f.read_text().strip()
    return label or raw


import unicodedata


def clean_title(t: str) -> str:
    """Strip cmux's leading status glyphs — spinner braille (⠙⠦⠐…), run/err/dirty
    emoji (🏃 ❌ ✳ …), and separators — leaving the human tab name."""
    i = 0
    while i < len(t):
        ch = t[i]
        if (ch.isspace() or unicodedata.category(ch).startswith("S")
                or 0x2800 <= ord(ch) <= 0x28FF or ord(ch) >= 0x1F000):
            i += 1
            continue
        break
    return t[i:].strip()


def cmux_workspace(ws_id: str) -> str:
    """The workspace name — ONLY when you gave it a custom title.

    cmux auto-titles an unnamed workspace from one of the agent tabs inside it, so
    the auto-title IS some tab's title — at best redundant with the tab label, at
    worst a DIFFERENT tab's name sitting under a "workspace" label. Unnamed means
    no workspace label; naming a workspace is what opts you into one, and its
    presence then tells you the workspace was named deliberately."""
    if not ws_id:
        return ""
    r = sh("cmux", "rpc", "workspace.list")
    if r.returncode == 0:
        try:
            for w in json.loads(r.stdout).get("workspaces", []):
                if w.get("id") == ws_id:
                    if w.get("has_custom_title") and w.get("custom_title"):
                        return clean_title(w["custom_title"])
                    break
        except Exception:
            pass
    return ""


def cmux_tab_title(surface_id: str) -> tuple[str, str]:
    """The per-tab (surface) title — the name you navigate by — plus its cmux
    ref (e.g. `surface:13`) ONLY when another tab shares the same title (so two
    "pulp" tabs are tellable apart, but unique names stay clean). JSON-driven
    from `cmux rpc surface.list`; re-running whence re-reads the current title."""
    if not surface_id:
        return "", ""
    r = sh("cmux", "rpc", "surface.list")
    if r.returncode == 0:
        try:
            surfaces = json.loads(r.stdout).get("surfaces", [])
            counts, mine = {}, None
            for s in surfaces:
                t = clean_title(s.get("title") or "")
                counts[t] = counts.get(t, 0) + 1
                if s.get("id") == surface_id:
                    mine = (t, s.get("ref") or "")
            if mine:
                t, ref = mine
                return t, (ref if t and counts.get(t, 0) > 1 else "")
        except Exception:
            pass
    return "", ""


def collect() -> dict:
    agent = os.environ.get("CMUX_AGENT_LAUNCH_KIND") or (
        "claude" if os.environ.get("CLAUDECODE") else
        "codex" if os.environ.get("CODEX_SESSION_ID") or os.environ.get("CODEX_ROLLOUT_ID") else
        "unknown")
    surface = os.environ.get("CMUX_SURFACE_ID", "")
    p = {f: "" for f in FIELDS}
    p["agent"] = agent
    p["host"] = host_label()
    p["workspace"] = cmux_workspace(os.environ.get("CMUX_WORKSPACE_ID", ""))
    tab, ref = cmux_tab_title(surface)
    p["tab"] = f"{tab} ({ref})" if (tab and ref) else tab
    p["stamped"] = datetime.datetime.now(datetime.timezone.utc).strftime("%Y-%m-%d %H:%M UTC")

    restore = ""
    if surface:
        r = sh("cmux", "surface", "resume", "get", "--surface", surface)
        if r.returncode == 0:
            restore = r.stdout.strip()
        p["jump"] = f"cmux surface focus {surface}"
        p["relaunch"] = f"cmux surface resume get --surface {surface}"  # exact cmd, any agent

    # Session id must be CONSISTENT with the detected agent — never pair claude's
    # session with codex's resume syntax (or vice versa) if both env vars leak in.
    if agent == "claude":
        sid = os.environ.get("CLAUDE_CODE_SESSION_ID", "")
    elif agent == "codex":
        sid = os.environ.get("CODEX_SESSION_ID") or os.environ.get("CODEX_ROLLOUT_ID") or ""
    else:
        sid = (os.environ.get("CLAUDE_CODE_SESSION_ID")
               or os.environ.get("CODEX_SESSION_ID") or os.environ.get("CODEX_ROLLOUT_ID") or "")
    if not sid and restore:
        m = re.search(r"[0-9a-fA-F]{8}-[0-9a-fA-F-]{27}", restore)
        sid = m.group(0) if m else ""
    p["session"] = sid

    if agent in KNOWN_RESUME and sid:
        p["resume"] = KNOWN_RESUME[agent].format(sid=sid)
    if agent in KNOWN_URL:
        bridge = os.environ.get("CLAUDE_CODE_BRIDGE_SESSION_ID", "")
        if bridge:
            p["url"] = KNOWN_URL[agent].format(bridge=bridge)
    return p


def visible(field: str, p: dict, hide: set) -> bool:
    return field not in hide and bool(p.get(field))


def _clip(s: str, n: int) -> str:
    """Shorten a label to ~n chars, ending with … — long tab/workspace names make
    unreadable queue chips. Prefers a whole-word break (may fall a little short of
    n rather than cut mid-word), but hard-caps a runaway single word so nothing
    blows past the limit. The full name always lives in the footer."""
    s = s.strip()
    if n <= 0 or len(s) <= n:
        return s[:50]  # GitHub's hard label max
    budget = max(1, n - 1)                       # leave room for the …
    head = s[:budget]
    sp = head.rfind(" ")
    if sp >= int(budget * 0.6):                  # a word break close enough to keep
        head = head[:sp]
    return head.rstrip() + "…"


def labels_for(p: dict, cfg: dict) -> list[tuple[str, str]]:
    out = []
    for f in LABEL_FIELDS:
        if visible(f, p, cfg["hide"]):
            out.append((_clip(p[f], cfg.get("label_maxlen", 24)), cfg["colors"].get(f, "ededed")))
    return out


def footer(p: dict, cfg: dict, label_names: list[str]) -> str:
    hide = cfg["hide"]
    tag = json.dumps({"labels": label_names}, ensure_ascii=False)
    line1 = "  ·  ".join(
        f"**{lbl}** {fmt}" for f, lbl, fmt in [
            ("agent", "Agent", f"`{p['agent']}`"),
            ("host", "Machine", f"`{p['host']}`"),
        ] if visible(f, p, hide))
    # navigation line: workspace then tab — the tab title is the "find my way back" key
    nav = "  ·  ".join(
        f"**{lbl}** {fmt}" for f, lbl, fmt in [
            ("workspace", "Workspace", f"`{p['workspace']}`"),
            ("tab", "Tab", f"`{p['tab']}`"),
        ] if visible(f, p, hide))
    rows = [r for r in (line1, nav) if r]
    for f, lbl, val in [
        ("session", "Session", f"`{p['session']}`"),
        ("resume", "Resume", f"`{p['resume']}`"),
        ("url", "Restore URL", p["url"]),
        ("jump", "Jump to this tab", f"`{p['jump']}`"),
        ("relaunch", "Relaunch (any agent)", f"`{p['relaunch']}`"),
    ]:
        if visible(f, p, hide):
            rows.append(f"**{lbl}** {val}")
    if visible("stamped", p, hide):
        rows.append(f"<sub>stamped {p['stamped']}</sub>")
    body = "  \n".join(r for r in rows if r)
    return f"<!-- whence {tag} -->\n\n---\n### 🔎 Provenance\n{body}\n<!-- /whence -->"


def resolve_pr(args) -> str:
    if args.pr:
        return str(args.pr)
    br = args.branch or sh("git", "rev-parse", "--abbrev-ref", "HEAD").stdout.strip()
    return sh(GH, "pr", "view", br, "--json", "number", "-q", ".number").stdout.strip()


def repo_allowed(cfg: dict, slug: str = "") -> bool:
    """Per-repo enable/disable. Two ways, either turns it off here:
    1. Drop a `.whence-off` file in the repo root  →  disabled in that repo.
    2. Global list in config: "repos": {"mode":"allow"|"deny","list":["owner/repo"]}.

    `slug` is the repo the COMMAND touched. Pass it whenever it's known: resolving
    the repo from the cwd instead would apply repo A's allow/deny rule to a PR in
    repo B (the hook's cwd is the session root, not where the command ran)."""
    top = sh("git", "rev-parse", "--show-toplevel").stdout.strip()
    if top and (pathlib.Path(top) / ".whence-off").exists() and not slug:
        return False
    r = cfg.get("repos") or {}
    mode = r.get("mode", "all")
    if mode == "all":
        return True
    slug = slug or sh(GH, "repo", "view", "--json", "nameWithOwner", "-q", ".nameWithOwner").stdout.strip()
    lst = set(r.get("list", []))
    if mode == "allow":
        return slug in lst
    if mode == "deny":
        return slug not in lst
    return True


# The one cross-agent trigger: wrap the command that opens the PR. Every agent
# shells out to one of these, so a PATH shim catches them all — no per-agent hook,
# no Shipyard requirement. Key = tool name, value = the sh test that means "a PR
# was just opened" (so the shim only stamps on PR-creating invocations). We cover
# every common way a PR gets opened: the GitHub CLIs (`gh`/`ghapp pr create`) and
# the orchestrators (`shipyard pr`, `pulp pr`). Over-firing is harmless — whence
# no-ops when the branch has no PR — so it's fine to err toward catching more.
PR_TOOLS = {
    "shipyard": '[ "$1" = pr ]',
    "pulp":     '[ "$1" = pr ]',
    "gh":       '[ "$1" = pr ] && [ "$2" = create ]',
    "ghapp":    '[ "$1" = pr ] && [ "$2" = create ]',
}
HOOK_MARK_RE = re.compile(r"\n*# >>> whence hook >>>.*?# <<< whence hook <<<\n", re.S)
HOOK_FILE = CFG_DIR / "hook.sh"


def _hook_source_block() -> str:
    return ("# >>> whence hook >>>  (managed by `whence --install-hook`; safe to delete)\n"
            f'[ -f "{HOOK_FILE}" ] && . "{HOOK_FILE}"\n'
            "# <<< whence hook <<<\n")


def _hook_file_text() -> tuple[str, list]:
    """Build the sourced functions file. A shell FUNCTION beats PATH lookup in
    EVERY shell mode (interactive or not), so — unlike a PATH-dir shim — it can't
    be shadowed by a later .zshrc reordering PATH. Each function runs the REAL
    tool via `command` (which skips functions → no recursion, and no double-stamp
    when one tool internally spawns another), then stamps best-effort."""
    from shutil import which
    tools = [(t, trig) for t, trig in PR_TOOLS.items() if which(t)]
    lines = [
        "# whence hook — sourced by your shell init. Thin wrappers around the",
        "# PR-opening commands that stamp the branch's PR right after it opens.",
        "# A function beats PATH, so this fires regardless of PATH order; `command`",
        "# runs the real tool (no recursion); the stamp never changes the exit code.",
        "# NB: `command whence` — plain `whence` is a zsh BUILTIN (like `which`), so",
        "# `command` is required to reach this script rather than the builtin.",
        "__whence_stamp() { command whence --auto >/dev/null 2>&1 || true; }",
    ]
    for tool, trig in tools:
        lines.append(
            f'{tool}() {{ command {tool} "$@"; __whence_rc=$?; '
            f"if {trig}; then __whence_stamp; fi; return $__whence_rc; }}")
    return "\n".join(lines) + "\n", [t for t, _ in tools]


def install_hook(print_only: bool) -> int:
    """Install (or print) the shell-function hook that stamps every future PR at
    open time, for any agent, without depending on Shipyard."""
    text, tools = _hook_file_text()
    block = _hook_source_block()
    if print_only:
        print(f"# hook file: {HOOK_FILE}")
        print(f"# wraps: {', '.join(tools) or '(no PR tool found on PATH)'}")
        print("\n# ---- hook.sh ----\n" + text)
        print("# add to ~/.zshenv (and ~/.bashrc if you use bash):\n" + block)
        return 0
    if not tools:
        print("whence: found no PR tool (shipyard/pulp/gh/ghapp) on PATH — nothing to wrap.\n"
              "  Install one, or wire an agent hook instead (see the README).", file=sys.stderr)
        return 1
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    HOOK_FILE.write_text(text)
    targets = [pathlib.Path(os.path.expanduser("~/.zshenv"))]  # always: universal zsh init
    bashrc = pathlib.Path(os.path.expanduser("~/.bashrc"))
    if bashrc.exists():
        targets.append(bashrc)
    for rcp in targets:
        cur = rcp.read_text() if rcp.exists() else ""
        cur = HOOK_MARK_RE.sub("\n", cur).rstrip()
        rcp.write_text((cur + "\n\n" + block) if cur else block)
    print(f"whence: wrote hook {HOOK_FILE}")
    print(f"  wraps: {', '.join(tools)}")
    print("  sourced from: " + ", ".join(str(t) for t in targets))
    print("Open a new shell/tab (or `source ~/.zshenv`) to activate. "
          "Every PR opened after that self-stamps.")
    return 0


def uninstall_hook() -> int:
    """Remove the hook file and the sourcing block — full reversal of --install-hook."""
    existed = HOOK_FILE.exists()
    if existed:
        HOOK_FILE.unlink()
    for rc in ("~/.zshenv", "~/.bashrc"):
        rcp = pathlib.Path(os.path.expanduser(rc))
        if not rcp.exists():
            continue
        cur = rcp.read_text()
        new = HOOK_MARK_RE.sub("\n", cur)
        new = new.rstrip() + "\n" if new.strip() else ""
        if new != cur:
            rcp.write_text(new)
    print(f"whence: removed hook {'file' if existed else '(none)'} and the sourcing block.")
    print("Open a new shell/tab for it to take full effect.")
    return 0


PR_HOOK = CFG_DIR / "pr-hook.sh"


def _write_pr_hook() -> pathlib.Path:
    """Write the tiny stdin shim an agent's PostToolUse hook runs. It just pipes
    the tool JSON into `whence --hook` (all parsing/matching happens in-process,
    so there's no fragile shell quoting). whence is called by absolute path
    because plain `whence` is a zsh builtin."""
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    whence_bin = os.path.realpath(sys.argv[0])
    PR_HOOK.write_text(
        "#!/bin/sh\n"
        "# whence agent PR hook — an agent PostToolUse hook pipes the tool-call JSON\n"
        "# to this on stdin. A cheap shell pre-filter avoids starting Python on the\n"
        "# ~99% of commands that clearly aren't a PR-open; whence --hook then does\n"
        "# the precise check (command field, not the whole payload) and stamps.\n"
        "# Always exits 0 so a stamping hiccup never breaks the agent.\n"
        "in=$(cat 2>/dev/null)\n"
        "# match only the command (in tool_input, before tool_response) — never the\n"
        "# command's OUTPUT — so a command whose output mentions a PR verb is ignored.\n"
        "# `git push` MUST be here: a push is how a PR the daemon opens later gets\n"
        "# its branch into the ledger, and dropping it here silently killed that.\n"
        'head=${in%%\\"tool_response\\"*}\n'
        "case \"$head\" in\n"
        "  *\"pr create\"*|*\"shipyard pr\"*|*\"pulp pr\"*|*\"git push\"*)\n"
        f'    printf \'%s\' "$in" | "{whence_bin}" --hook || true ;;\n'
        "esac\n"
        "exit 0\n")
    PR_HOOK.chmod(0o755)
    return PR_HOOK


def _wire_posttooluse(path: pathlib.Path, matcher: str, extra: dict) -> None:
    """Idempotently add a PostToolUse entry pointing at pr-hook.sh to a Claude/
    Codex-style hooks JSON (they share the schema)."""
    d = {}
    if path.exists():
        try: d = json.loads(path.read_text())
        except Exception: d = {}
    ptu = d.setdefault("hooks", {}).setdefault("PostToolUse", [])
    cmd = str(PR_HOOK)
    def has(e): return any(x.get("command", "").endswith("pr-hook.sh") for x in e.get("hooks", []))
    mine = [e for e in ptu if e.get("matcher") == matcher or has(e)]
    entry = {"type": "command", "command": cmd, **extra}
    if any(has(e) for e in ptu):
        for e in ptu:
            if has(e):
                e["hooks"] = [x for x in e["hooks"] if not x.get("command", "").endswith("pr-hook.sh")] + [entry]
    elif mine:
        mine[0].setdefault("hooks", []).append(entry)
    else:
        ptu.append({"matcher": matcher, "hooks": [entry]})
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(d, indent=2) + "\n")


def install_agent_hook(scope: str) -> int:
    """Wire the reliable in-process agent hooks: Claude globally, Codex per-repo
    (Codex only reads a repo's own .codex/hooks.json, and gates it behind trust)."""
    _write_pr_hook()
    did = []
    if scope in ("all", "claude"):
        _wire_posttooluse(pathlib.Path(os.path.expanduser("~/.claude/settings.json")),
                          "Bash", {})
        did.append("claude (~/.claude/settings.json, global)")
    if scope in ("all", "codex"):
        _wire_posttooluse(pathlib.Path(os.path.expanduser("~/.codex/hooks.json")),
                          "Bash|Shell|shell|local_shell|exec", {"timeout": 20000})
        did.append("codex (~/.codex/hooks.json, global)")
    print(f"whence: wrote {PR_HOOK}")
    for d in did:
        print(f"  wired {d}")
    if scope in ("all", "codex"):
        print("\nCodex note: this is Codex's GLOBAL hooks file — it applies to every repo,\n"
              "no per-repo install. Codex gates hooks behind trust, so it will ask you to\n"
              "trust the whence hook once on its next run.")
    return 0


SWEEP_PLIST = pathlib.Path(os.path.expanduser(
    "~/Library/LaunchAgents/com.whence.sweep.plist"))
SWEEP_EVERY = 600


def install_sweep(uninstall: bool = False) -> int:
    """Run the sweep on a timer instead of only when an agent happens to fire the
    hook again.

    Without this, the LAST PR of a session is never swept: the hook's sweep is
    opportunistic (it piggybacks on the next push/PR command in that shell), so a
    session that opens a PR and stops leaves it unstamped forever. macOS only —
    elsewhere, add `whence --sweep` to cron (the sweep is idempotent and, once
    entries are marked done, costs no API calls)."""
    if sys.platform != "darwin":
        print(f"whence: not macOS — add this to cron instead:\n"
              f"  */{SWEEP_EVERY // 60} * * * * {os.path.realpath(sys.argv[0])} --sweep")
        return 0
    label = "com.whence.sweep"
    if uninstall:
        sh("launchctl", "bootout", f"gui/{os.getuid()}/{label}")
        if SWEEP_PLIST.exists():
            SWEEP_PLIST.unlink()
        print("whence: removed the sweep timer")
        return 0
    whence_bin = os.path.realpath(sys.argv[0])
    # launchd starts with a bare PATH; gh/ghapp/git live in the user's dirs.
    path = ":".join([os.path.expanduser("~/.local/bin"), "/opt/homebrew/bin",
                     "/usr/local/bin", "/usr/bin", "/bin", "/usr/sbin", "/sbin"])
    SWEEP_PLIST.parent.mkdir(parents=True, exist_ok=True)
    SWEEP_PLIST.write_text(f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>{label}</string>
  <key>ProgramArguments</key>
  <array><string>{sys.executable}</string><string>{whence_bin}</string><string>--sweep</string></array>
  <key>EnvironmentVariables</key>
  <dict><key>PATH</key><string>{path}</string></dict>
  <key>StartInterval</key><integer>{SWEEP_EVERY}</integer>
  <key>RunAtLoad</key><true/>
  <key>ProcessType</key><string>Background</string>
</dict>
</plist>
""")
    sh("launchctl", "bootout", f"gui/{os.getuid()}/{label}")
    r = sh("launchctl", "bootstrap", f"gui/{os.getuid()}", str(SWEEP_PLIST))
    if r.returncode != 0:
        print(f"whence: could not load the sweep timer: {r.stderr.strip()}", file=sys.stderr)
        return 1
    print(f"whence: sweep timer every {SWEEP_EVERY // 60}m ({SWEEP_PLIST})")
    return 0


def _best_gh() -> str:
    """Pick the GitHub CLI to use for whence's own calls: gh if present, else
    ghapp (App-token). Lets machines that only have ghapp work with zero config."""
    from shutil import which
    return "gh" if which("gh") else ("ghapp" if which("ghapp") else "gh")


def setup(host: str | None) -> int:
    """One-shot guided setup: name the machine, write the config (auto-picking the
    GitHub CLI), and install the every-future-PR hook. Reports what it will catch."""
    from shutil import which
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    hf = CFG_DIR / "host-label"
    if host and host.strip():
        hf.write_text(host.strip() + "\n"); hs = host.strip()
    elif hf.exists() and hf.read_text().strip():
        hs = hf.read_text().strip()
    else:
        hs = socket.gethostname().split(".")[0]
        hf.write_text(hs + "\n")
    cf = CFG_DIR / "config.json"
    cfg = dict(DEFAULT_CONFIG)
    if cf.exists():
        try: cfg = json.loads(cf.read_text())
        except Exception: pass
    # Auto-pick the GitHub CLI unless the user already set a non-default one.
    if not cfg.get("gh") or cfg.get("gh") == "gh":
        cfg["gh"] = _best_gh()
    cf.write_text(json.dumps(cfg, indent=2) + "\n")

    print(f"whence setup")
    print(f"  machine label : {hs}   ({hf})")
    print(f"  github CLI    : {cfg['gh']}   (for whence's own calls)")
    print(f"  config        : {cf}")
    have = [t for t in PR_TOOLS if which(t)]
    print(f"  will catch PRs opened via: {', '.join(have) or '(none found — install gh/ghapp/shipyard/pulp)'}")
    print()
    rc = install_hook(print_only=False)
    print()
    install_agent_hook("all")   # the in-process hook: sees worktrees the shell can't
    print()
    install_sweep()             # the backstop: catches whatever both hooks missed
    print("\nSetup complete. New PRs from this machine self-stamp once you open a fresh shell/tab.")
    return rc


def resync() -> int:
    """Refresh THIS tab's open PRs with the current name — on demand, no tracking.
    Each PR whence stamped carries this tab's stable surface id in its footer, so
    we just search open PRs for it and re-stamp (idempotent). Run it after you
    rename a tab; nothing monitors in the background."""
    surface = os.environ.get("CMUX_SURFACE_ID", "")
    if not surface:
        print("whence: no CMUX_SURFACE_ID in this shell — can't identify this tab's PRs",
              file=sys.stderr)
        return 2
    r = sh(GH, "pr", "list", "--state", "open", "--search", surface,
           "--json", "number", "-q", ".[].number")
    nums = [x for x in r.stdout.split() if x.strip()]
    if not nums:
        print("whence: no open PRs stamped from this tab — nothing to resync")
        return 0
    print(f"whence: refreshing {len(nums)} open PR(s) from this tab: "
          + ", ".join("#" + n for n in nums))
    self = os.path.realpath(sys.argv[0])
    for n in nums:
        sh(sys.executable, self, "--pr", n, "--apply")
        print(f"  #{n} refreshed")
    return 0


def write_default_config(force: bool) -> None:
    CFG_DIR.mkdir(parents=True, exist_ok=True)
    f = CFG_DIR / "config.json"
    if f.exists() and not force:
        print(f"whence: config already exists at {f}\n"
              f"  edit it, or re-run `whence --init --force` to reset it to defaults")
        return
    f.write_text(json.dumps(DEFAULT_CONFIG, indent=2) + "\n")
    print(f"whence: wrote {f}\n"
          f"  Flip any \"fields\" value to false to drop it (labels + footer).\n"
          f"  Set \"labels\": false or \"footer\": false to drop a whole surface.\n"
          f"  Scope repos with \"repos\": {{\"mode\":\"allow\"|\"deny\",\"list\":[\"owner/repo\"]}}.")


def prior_labels(body: str) -> list:
    m = re.search(r"<!-- whence (\{.*?\}) -->", body)
    if m:
        try: return json.loads(m.group(1)).get("labels", [])
        except Exception: pass
    return []


def _now_epoch() -> int:
    return int(datetime.datetime.now(datetime.timezone.utc).timestamp())


def _throttled(name: str, secs: int) -> bool:
    """True at most once per `secs`, recording the tick — so the maintenance the
    hook does (sweep, self-update) doesn't run on every single tool call."""
    st = CFG_DIR / f".last-{name}"
    try: last = int(st.read_text().strip())
    except Exception: last = 0
    if _now_epoch() - last < secs:
        return False
    st.parent.mkdir(parents=True, exist_ok=True)
    st.write_text(str(_now_epoch()))
    return True


def is_stamped(body: str) -> bool:
    return bool(MARK_RE.search(body or ""))


def apply_stamp(pr: str, p: dict, cfg: dict, post_labels: bool, post_footer: bool,
                repo: str = "") -> list:
    """Write the labels + footer for provenance `p` onto PR #pr. Idempotent:
    replaces whence's own prior labels/footer, never stacks. Shared by the live
    hook path and the ledger sweep so both stamp identically.

    `repo` ("owner/name") is REQUIRED for correctness whenever the caller knows
    it: without it every `gh` call resolves the PR number against the cwd's repo,
    so a sweep running from an unrelated checkout would stamp a same-numbered PR
    in the WRONG repository."""
    R = ["--repo", repo] if repo else []
    labels = labels_for(p, cfg) if post_labels else []
    names = [n for n, _ in labels]
    ft = footer(p, cfg, names) if post_footer else ""
    body = sh(GH, "pr", "view", pr, *R, "--json", "body", "-q", ".body").stdout
    keep = set(names)
    existing = sh(GH, "pr", "view", pr, *R, "--json", "labels", "-q", ".labels[].name").stdout.split("\n")
    stale = (set(prior_labels(body)) | {l for l in existing if l and l.startswith(OLD_PREFIXES)}) - keep
    for s in sorted(x for x in stale if x):
        sh(GH, "pr", "edit", pr, *R, "--remove-label", s)
    for n, c in labels:
        sh(GH, "label", "create", n, *R, "--color", c, "--force")
    if names:
        sh(GH, "pr", "edit", pr, *R, *sum([["--add-label", n] for n in names], []))
    stripped = MARK_RE.sub("", body).rstrip()
    newbody = (stripped + "\n\n" + ft) if post_footer else (stripped + "\n")
    if newbody != body:
        fd, tmpname = tempfile.mkstemp(prefix="whence-body-", suffix=".md")
        try:
            os.write(fd, newbody.encode()); os.close(fd)
            sh(GH, "pr", "edit", pr, *R, "--body-file", tmpname)
        finally:
            try: os.unlink(tmpname)
            except OSError: pass
    return names


# ── Branch→provenance ledger + sweep ────────────────────────────────────────
# Reliable coverage without an orchestrator hook. The live in-shell stamp only
# sees a PR it can resolve at push time from the agent's cwd — it MISSES a PR
# opened inside a git worktree (the hook runs from the home cwd, wrong branch),
# one opened later by a detached daemon (e.g. shipyard-local), one opened
# elsewhere while this shell only pushed, and one whose create command was
# killed before the hook ran. So split the work: CAPTURE the branch's provenance
# when the push/PR command fires (env is live then), and SWEEP later — stamp
# whatever PR turns up for that branch, using the captured provenance. Keyed on
# the git branch, which every path shares, so it needs no Shipyard dependency.
LEDGER = CFG_DIR / "branch-ledger.json"
DEFAULT_BRANCHES = {"main", "master", "trunk", "develop"}


def _git(cwd, *a):
    return sh("git", "-C", cwd, *a) if cwd else sh("git", *a)


_CD_RE = re.compile(r"""(?:^|&&|\|\||;|\n)\s*cd\s+('[^']*'|"[^"]*"|[^\s;&|]+)""")
_GIT_C_RE = re.compile(r"""\bgit\s+-C\s+('[^']*'|"[^"]*"|[^\s;&|]+)""")
_ASSIGN_RE = re.compile(r"""(?:^|&&|;|\n)\s*(\w+)=('[^']*'|"[^"]*"|[^\s;&|]+)""")


def _cmd_cwd(cmd: str):
    """The directory the command actually ran in, read out of the command itself.

    This is what stands between a worktree PR and no label at all. A backgrounded
    `shipyard pr` returns no output for parse_outcome to read, and the hook's own
    cwd is the session root — so the `cd` in the command text is the ONLY thing
    left that names the worktree. It has to handle how the commands are really
    written, not just the tidy form:

        cd /wt && shipyard pr          cd on one line, command on the next
        WT=/wt                         a variable, expanded below
        cd "$WT"                       quoted, and referencing that variable
        git -C /wt push                no cd at all

    Takes the LAST cd (a command may cd twice), and only accepts a real directory
    — a path that doesn't resolve means we learned nothing, not that we're in it."""
    if not cmd:
        return None
    vars_ = {k: v.strip("'\"") for k, v in _ASSIGN_RE.findall(cmd)}

    def resolve(raw: str):
        v = raw.strip().strip("'\"")
        # $VAR / ${VAR} — only ones this same command assigned; no shell, no eval.
        v = re.sub(r"\$\{?(\w+)\}?", lambda m: vars_.get(m.group(1), ""), v)
        v = os.path.expanduser(os.path.expandvars(v))
        return v if v and os.path.isdir(v) else None

    for rx in (_CD_RE, _GIT_C_RE):
        for m in reversed(list(rx.finditer(cmd))):
            got = resolve(m.group(1))
            if got:
                return got
    return None


def _repo_branch(cwd):
    url = _git(cwd, "config", "--get", "remote.origin.url").stdout.strip()
    m = re.search(r"[:/]([^/]+/[^/]+?)(?:\.git)?$", url)
    slug = m.group(1) if m else ""
    br = _git(cwd, "rev-parse", "--abbrev-ref", "HEAD").stdout.strip()
    return slug, br


def _load_ledger() -> dict:
    try: return json.loads(LEDGER.read_text()) if LEDGER.exists() else {}
    except Exception: return {}


def ledger_record(cmd: str, p: dict, slug: str = "", br: str = "") -> None:
    """Remember which tab/session/machine owns this branch, keyed owner/repo#branch.

    `slug`/`br` come from the command's own output when it named them — always
    correct. Only when it named neither do we fall back to reading git in the
    hook's cwd, which is right just when the command ran in the session's root
    checkout (and wrong, silently, for every worktree)."""
    if not slug or not br:
        c_slug, c_br = _repo_branch(_cmd_cwd(cmd))
        slug, br = slug or c_slug, br or c_br
    if not slug or not br or br in ("HEAD", ""):
        return
    if br in DEFAULT_BRANCHES:
        # A push to main is not a PR branch. Recording it would leave the sweep
        # asking "any PR with head=main?" — and stamp whatever unrelated PR that
        # matched, with this session's provenance.
        return
    led = _load_ledger()
    led[f"{slug}#{br}"] = {"p": {k: p.get(k, "") for k in FIELDS}, "ts": _now_epoch()}
    LEDGER.parent.mkdir(parents=True, exist_ok=True)
    LEDGER.write_text(json.dumps(led))


def sweep(cfg: dict) -> int:
    """Stamp every PR whose head branch is in the ledger but isn't stamped yet,
    using the LEDGER's provenance (the tab that made the branch) — never the
    sweeping session's. Idempotent; prunes ledger entries older than 14 days.

    `--state all`, NOT just open: an orchestrator that merges on green closes the
    PR within minutes, so an open-only sweep loses exactly the PRs that sailed
    through — and a merged PR is the one you most want to trace back later. An
    entry is marked done once stamped, so a steady-state sweep costs no API calls
    and the timer can run often."""
    led = _load_ledger()
    if not led:
        return 0
    post_labels, post_footer = cfg["labels"], cfg["footer"]
    now, keep, n = _now_epoch(), {}, 0
    for key, rec in led.items():
        if now - rec.get("ts", 0) > 14 * 86400:
            continue
        keep[key] = rec
        slug, _, br = key.partition("#")
        if not slug or not br or rec.get("done"):
            continue
        res = sh(GH, "pr", "list", "--repo", slug, "--head", br,
                 "--state", "all", "--json", "number,body")
        try: prs = json.loads(res.stdout or "[]")
        except Exception: prs = []
        for pr in prs:
            if is_stamped(pr.get("body", "")):
                rec["done"] = True
                continue
            p = {f: rec["p"].get(f, "") for f in FIELDS}
            apply_stamp(str(pr["number"]), p, cfg, post_labels, post_footer, repo=slug)
            rec["done"] = True
            n += 1
    LEDGER.write_text(json.dumps(keep))
    return n


# ── Multi-machine sync: self-update (pull) + deploy (fan-out) ────────────────
# Any machine can be the one you edit whence on. Two mechanisms keep the rest
# current: self_update() converges each machine to origin/main automatically
# (throttled, from the hook — no cron, no push from the author); deploy() pushes
# your change and SSHes your personal host list to pull+reinstall instantly. The
# host list lives only in ~/.config/whence/hosts, never in the repo, because it's
# specific to your fleet — other whence users don't need it.
HOSTS = CFG_DIR / "hosts"


def _self_clone() -> pathlib.Path:
    here = pathlib.Path(__file__).resolve().parent
    return here if (here / ".git").exists() else (pathlib.Path.home() / ".local/share/whence")


def self_update(force: bool = False) -> bool:
    """Fast-forward this whence clone to origin/main so every machine picks up a
    change made on any other machine — no matter which one made it. Throttled to
    once/day from the hook; reinstalls the agent hook only if the clone moved."""
    clone = _self_clone()
    if not (clone / ".git").exists():
        return False
    if not force and not _throttled("selfupdate", 86400):
        return False
    before = _git(str(clone), "rev-parse", "HEAD").stdout.strip()
    _git(str(clone), "pull", "--ff-only", "--quiet")
    after = _git(str(clone), "rev-parse", "HEAD").stdout.strip()
    if before and after and before != after:
        install_agent_hook("all")
        return True
    return False


def deploy() -> int:
    """Push local whence changes, then SSH each host in ~/.config/whence/hosts to
    pull + reinstall — instant propagation from whichever machine you edited on.
    Unreachable hosts are skipped (they self-update on their next stamp)."""
    clone = _self_clone()
    ahead = _git(str(clone), "rev-list", "--count", "@{u}..HEAD").stdout.strip()
    if ahead not in ("", "0"):
        r = _git(str(clone), "push")
        print("pushed local whence changes" if r.returncode == 0 else "local push FAILED")
    if not HOSTS.exists():
        print(f"whence: no host list — add one hostname per line to {HOSTS}")
        return 0
    hosts = [h.strip() for h in HOSTS.read_text().splitlines()
             if h.strip() and not h.lstrip().startswith("#")]
    rc = 0
    for h in hosts:
        remote = ("cd ~/.local/share/whence && git pull --ff-only --quiet && "
                  "./whence --install-agent-hook all >/dev/null 2>&1 && echo whence-ok")
        r = sh("ssh", "-o", "ConnectTimeout=8", h, remote)
        ok = r.returncode == 0 and "whence-ok" in r.stdout
        print(f"  {h}: {'updated' if ok else 'unreachable — will self-update on next stamp'}")
        rc = rc or (0 if ok else 1)
    return rc


def main() -> int:
    global GH
    ap = argparse.ArgumentParser(description="Stamp a PR with agent/session/machine/tab provenance.")
    ap.add_argument("--pr"); ap.add_argument("--branch")
    ap.add_argument("--hide", help="comma list of fields to omit this run: " + ",".join(FIELDS))
    ap.add_argument("--no-footer", action="store_true", help="don't post the PR-description footer")
    ap.add_argument("--no-labels", action="store_true", help="don't post the queue labels")
    ap.add_argument("--apply", action="store_true", help="mutate the PR (default: dry-run)")
    ap.add_argument("--auto", action="store_true",
                    help="hook mode: apply, quiet, skip silently if the repo is off or has no PR")
    ap.add_argument("--init", action="store_true", help="write an editable config with every knob")
    ap.add_argument("--install-sweep", action="store_true",
                    help="run the ledger sweep on a timer (launchd, every 10m)")
    ap.add_argument("--uninstall-sweep", action="store_true", help="remove the sweep timer")
    ap.add_argument("--force", action="store_true", help="with --init, overwrite an existing config")
    ap.add_argument("--show", action="store_true", help="print the effective config and where it lives")
    ap.add_argument("--setup", action="store_true",
                    help="guided one-shot: name the machine, write config, install the hook")
    ap.add_argument("--host", help="machine label to use with --setup (default: hostname)")
    ap.add_argument("--install-hook", action="store_true",
                    help="install the PATH shim so every future PR self-stamps (any agent)")
    ap.add_argument("--uninstall-hook", action="store_true",
                    help="remove the shim and PATH block (full reversal of --install-hook)")
    ap.add_argument("--print-hook", action="store_true",
                    help="print the shim + shell snippet without writing anything")
    ap.add_argument("--resync", action="store_true",
                    help="re-stamp this tab's open PRs with the current name (on demand)")
    ap.add_argument("--sweep", action="store_true",
                    help="stamp any open PR in the branch-ledger that isn't stamped yet "
                         "(catches worktree/daemon/push-only/timed-out PRs)")
    ap.add_argument("--deploy", action="store_true",
                    help="push local whence changes, then SSH ~/.config/whence/hosts to pull+reinstall")
    ap.add_argument("--self-update", dest="selfupdate", action="store_true",
                    help="fast-forward this whence clone to the repo now and reinstall the hook")
    ap.add_argument("--install-agent-hook", nargs="?", const="all", choices=["all", "claude", "codex"],
                    metavar="all|claude|codex",
                    help="wire the reliable in-process agent hook (Claude global, Codex per-repo)")
    ap.add_argument("--hook", action="store_true",
                    help="internal: read an agent's tool JSON from stdin and stamp if it opened a PR")
    args = ap.parse_args()

    if args.install_agent_hook:
        return install_agent_hook(args.install_agent_hook)
    if args.deploy:
        return deploy()
    if args.selfupdate:
        print("whence: updated to latest" if self_update(force=True) else "whence: already current")
        return 0
    if args.resync:
        cfg = load_config(args.hide)
        GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"
        return resync()
    if args.sweep:
        cfg = load_config(args.hide)
        GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"
        print(f"whence: swept {sweep(cfg)} PR(s)")
        return 0
    if args.setup:
        return setup(args.host)
    if args.print_hook:
        return install_hook(print_only=True)
    if args.install_hook:
        return install_hook(print_only=False)
    if args.uninstall_hook:
        return uninstall_hook()
    if args.init:
        write_default_config(args.force); return 0
    if args.install_sweep:
        return install_sweep()
    if args.uninstall_sweep:
        return install_sweep(uninstall=True)

    cfg = load_config(args.hide)
    GH = os.environ.get("WHENCE_GH") or cfg.get("gh") or "gh"   # env > config "gh" > "gh"

    hook_agent = hook_sid = hook_cmd = ""
    hook_slug = hook_br = hook_pr = ""
    hook_is_pr = hook_is_push = False
    if args.hook:
        # Agent PostToolUse: read the tool JSON. A PR-create command stamps now;
        # a push (which may open a PR later, via a daemon) records the branch's
        # provenance for the sweep. The payload carries the true identity
        # (session_id + transcript_path), more reliable than leak-prone env vars.
        if sys.stdin.isatty():   # run by hand with no piped input — don't block
            return 0
        try: raw = sys.stdin.read()
        except Exception: raw = ""
        try:
            d = json.loads(raw); ti = d.get("tool_input") or d.get("toolInput") or {}
            hook_cmd = ti.get("command") or ti.get("cmd") or ""
            hook_sid = d.get("session_id") or ""
            tp = d.get("transcript_path") or ""
            hook_agent = ("codex" if "/.codex" in tp else
                          "claude" if "/.claude" in tp else "")
            hook_slug, hook_br, hook_pr = parse_outcome(d)
        except Exception:
            hook_cmd = ""
        # The output outranks the command name: anything that printed a PR URL
        # opened a PR, no matter which wrapper it was spelled with.
        hook_is_pr = bool(hook_pr) or bool(PR_CMD_RE.search(hook_cmd or ""))
        hook_is_push = bool(PUSH_RE.search(hook_cmd or "")) or bool(hook_slug and hook_br)
        if not (hook_is_pr or hook_is_push):
            return 0
        args.auto = True   # quiet mode for both; a push returns before stamping

    post_labels = cfg["labels"] and not args.no_labels
    post_footer = cfg["footer"] and not args.no_footer

    if args.show:
        f = CFG_DIR / "config.json"
        shown = [x for x in FIELDS if x not in cfg["hide"]]
        rp = cfg.get("repos") or {}
        scope = rp.get("mode", "all")
        print(f"config file:  {f}  ({'exists' if f.exists() else 'not created — run: whence --init'})")
        print(f"per-repo off: drop a `.whence-off` file in a repo's root to disable it there")
        print(f"\nlabels posted: {post_labels}    footer posted: {post_footer}")
        print(f"fields shown:  {', '.join(shown) or '(none)'}")
        print(f"fields hidden: {', '.join(sorted(cfg['hide'])) or '(none)'}")
        print(f"repo scope:    {scope}" + (f"  {rp.get('list', [])}" if scope != "all" else "  (every repo)"))
        return 0

    if not repo_allowed(cfg, hook_slug):
        if not args.auto:
            print("whence: this repo is disabled (.whence-off file or repos config) — skipping")
        return 0

    p = collect()
    if args.hook:
        # Prefer the hook payload's identity over env (which can leak across
        # sessions): the session id is authoritative; use the transcript's agent
        # only when env couldn't name one. Keep resume consistent with both.
        if hook_agent and p["agent"] in ("", "unknown"):
            p["agent"] = hook_agent
        if hook_sid:
            p["session"] = hook_sid
        if p["agent"] in KNOWN_RESUME and p["session"]:
            p["resume"] = KNOWN_RESUME[p["agent"]].format(sid=p["session"])
        elif p["agent"] not in KNOWN_RESUME:
            p["resume"] = ""
        # Capture this branch's provenance while the env is live, then run the
        # cheap throttled maintenance: converge to the repo + backfill any PR the
        # live stamp couldn't reach (worktree / daemon / push-only / timed-out).
        if hook_is_pr or hook_is_push:
            ledger_record(hook_cmd, p, hook_slug, hook_br)
        try: self_update()                       # throttled once/day internally
        except Exception: pass
        try:
            if _throttled("sweep", 120): sweep(cfg)
        except Exception: pass
        if not hook_is_pr:                        # a push only records + sweeps
            return 0
    labels = labels_for(p, cfg) if post_labels else []
    names = [n for n, _ in labels]
    ft = footer(p, cfg, names) if post_footer else ""

    if not args.auto:
        print("── Provenance ──")
        for k in FIELDS:
            print(f"  {k:9} {p[k]}" + ("" if visible(k, p, cfg['hide']) else "  (hidden)"))
        print("\n── Labels ──" if post_labels else "\n── Labels (disabled) ──")
        for n, c in labels:
            print(f"  #{c}  {n}")
        print("\n── Footer ──\n" + ft if post_footer else "\n── Footer (disabled) ──")
    if not args.apply and not args.auto:
        print("\n[dry-run] pass --apply to stamp the PR")
        return 0

    pr, repo = (hook_pr, hook_slug) if hook_pr else (resolve_pr(args), "")
    if not pr:
        # The command opened no PR we can name (e.g. a plain push, or a PR the
        # daemon opens later). It's in the ledger — the sweep will catch it.
        if args.auto:
            return 0
        print("whence: could not resolve a PR", file=sys.stderr); return 2

    names = apply_stamp(pr, p, cfg, post_labels, post_footer, repo=repo)
    print(f"\n✓ PR #{pr}: " + (", ".join(names) if names else "labels off")
          + (" + footer" if post_footer else " · footer off"))
    return 0


if __name__ == "__main__":
    sys.exit(main())
