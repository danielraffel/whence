    ap.add_argument("--reorder-labels", metavar="OWNER/REPO",
                    help="force open-PR label chips into agent/host/workspace/tab order")
    ap.add_argument("--log", nargs="?", type=int, const=20, metavar="N",
                    help="show the last N audit entries (label changes; default 20)")
    ap.add_argument("--audit", choices=("on", "off"),
                    help="turn the audit log on/off (syncs to the fleet via config)")
    ap.add_argument("--force", action="store_true", help="with --init, overwrite an existing config")
